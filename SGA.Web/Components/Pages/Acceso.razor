@page "/acceso"

<section class="sga-section">
    <h1>Acceso por rol</h1>
    <p class="lead">Selecciona un portal para iniciar tu flujo de trabajo.</p>

    <div class="portal-grid">
        <a class="portal-card" href="/login-portal?portal=admin">
            <img src="icons/nav/shield.svg" alt="admin" />
            <h3>Administrador</h3>
            <p>Gestiona instituciones, permisos y configuracion global.</p>
            <span class="sga-btn">Entrar</span>
        </a>

        <a class="portal-card" href="/login-portal?portal=operador">
            <img src="icons/transport/bus.svg" alt="operador" />
            <h3>Operador</h3>
            <p>Administra buses, rutas y viajes operativos.</p>
            <span class="sga-btn alt">Entrar</span>
        </a>

        <a class="portal-card" href="/login-portal?portal=driver">
            <img src="icons/nav/user.svg" alt="driver" />
            <h3>Driver</h3>
            <p>Consulta viajes activos y reporta su estado.</p>
            <span class="sga-btn">Entrar</span>
        </a>

        <a class="portal-card" href="/portal/cliente-estudiante">
            <img src="icons/nav/users.svg" alt="cliente" />
            <h3>Cliente</h3>
            <p>Reserva de forma rapida y descarga tu ticket con QR.</p>
            <span class="sga-btn alt">Reservar</span>
        </a>
    </div>
</section>