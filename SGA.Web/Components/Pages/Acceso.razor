@page "/acceso"

<section class="sga-section">
    <h1>Acceso por rol</h1>
    <p class="lead">Elige el tipo de usuario para entrar al portal correspondiente.</p>

    <div class="portal-grid">
        <a class="portal-card" href="/portal/admin">
            <h3>Administrador</h3>
            <p>Gestion de roles, permisos y configuraciones base.</p>
        </a>

        <a class="portal-card" href="/portal/operador">
            <h3>Operador</h3>
            <p>Registrar viajes y gestionar su ciclo operativo.</p>
        </a>

        <a class="portal-card" href="/portal/driver">
            <h3>Driver</h3>
            <p>Visualizar viajes activos y cambiar su estado.</p>
        </a>

        <a class="portal-card" href="/portal/cliente-estudiante">
            <h3>Cliente y Estudiante</h3>
            <p>Acceso libre para reservar seleccionando institucion y viaje.</p>
        </a>
    </div>
</section>