@page "/login-portal"
@rendermode InteractiveServer
@inject SGA.Web.Services.SgaApiClient ApiClient
@inject SGA.Web.Services.PortalSessionService Session
@inject NavigationManager Navigation
@inject SGA.Web.Services.UiFeedbackService Ui
@inject SGA.Web.Services.UiErrorHandler ErrorHandler

<section class="sga-section">
    <h1>Validar acceso por rol</h1>
    <p class="lead">Ingresa tu correo y valida el OTP de 6 digitos enviado al email.</p>

    <div class="sga-form-full single-col">
        <div class="sga-field">
            <label>Portal</label>
            <select class="sga-input" @bind="portal">
                <option value="admin">Administrador</option>
                <option value="operador">Operador</option>
                <option value="driver">Driver</option>
            </select>
        </div>

        <div class="sga-field">
            <label>Correo del usuario</label>
            <div class="sga-input-status-wrap">
                <input class="@GetInputCssClass(emailError)" @bind="email" @bind:event="oninput" @bind:after="OnEmailInput" type="email" placeholder="usuario@correo.com" />
                <span class="sga-input-status-icon">@GetStatusIcon(emailError, email)</span>
            </div>
            <small class="@GetStatusCssClass(emailError)">@GetStatusText(emailError, "Email valido")</small>
        </div>

        @if (showOtpStep)
        {
            <div class="sga-field">
                <label>Codigo OTP (6 digitos)</label>
                <div class="sga-input-status-wrap">
                    <input class="@GetInputCssClass(otpError)" @bind="otpCode" @bind:event="oninput" @bind:after="OnOtpInput" maxlength="6" placeholder="123456" />
                    <span class="sga-input-status-icon">@GetStatusIcon(otpError, otpCode)</span>
                </div>
                <small class="@GetStatusCssClass(otpError)">@GetStatusText(otpError, "Codigo OTP valido")</small>
            </div>
            <button class="sga-btn alt" disabled="@(!CanVerifyOtp)" @onclick="VerifyOtpAsync">Validar codigo</button>
        }
        else
        {
            <button class="sga-btn" disabled="@(!CanRequestOtp)" @onclick="RequestOtpAsync">Enviar codigo OTP</button>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <p class="sga-alert">@message</p>
    }
</section>

@code {
    [SupplyParameterFromQuery]
    private string? portal { get; set; }

    private string email = string.Empty;
    private string otpCode = string.Empty;
    private bool showOtpStep;
    private string? message;
    private string? emailError;
    private string? otpError;

    private bool CanRequestOtp => string.IsNullOrWhiteSpace(emailError) && !string.IsNullOrWhiteSpace(email);
    private bool CanVerifyOtp => CanRequestOtp && string.IsNullOrWhiteSpace(otpError) && !string.IsNullOrWhiteSpace(otpCode);

    protected override void OnInitialized()
    {
        portal = NormalizePortal(portal);
        ValidateEmail();
        ValidateOtp();
    }

    private async Task RequestOtpAsync()
    {
        using var busy = Ui.BeginBusy("Enviando codigo OTP...");
        message = null;
        ValidateEmail();

        if (!CanRequestOtp)
        {
            message = emailError ?? "El correo es obligatorio.";
            Ui.ShowWarning("Correo invalido", message);
            return;
        }

        try
        {
            var otpResponse = await ApiClient.RequestOtpAsync(new SGA.Web.Models.OtpRequest(email.Trim()), CancellationToken.None);
            showOtpStep = true;
            message = otpResponse?.DevelopmentCode is null
                ? otpResponse?.Message ?? "Se envio un codigo OTP al correo indicado."
                : $"{otpResponse.Message} Codigo OTP DEV: {otpResponse.DevelopmentCode}";
            Ui.ShowInfo("OTP solicitado", message);
        }
        catch (Exception ex)
        {
            message = ErrorHandler.Handle(ex, "No se pudo solicitar el OTP");
        }
    }

    private async Task VerifyOtpAsync()
    {
        using var busy = Ui.BeginBusy("Validando codigo OTP...");
        message = null;
        ValidateEmail();
        ValidateOtp();

        if (!CanVerifyOtp)
        {
            message = otpError ?? "Ingresa un codigo OTP valido de 6 digitos.";
            Ui.ShowWarning("Codigo OTP invalido", message);
            return;
        }

        try
        {
            var profile = await ApiClient.VerifyOtpAsync(
                new SGA.Web.Models.OtpVerifyRequest(email.Trim(), otpCode.Trim()),
                CancellationToken.None);

            if (profile is null)
            {
                message = "No se pudo validar el codigo OTP.";
                Ui.ShowError("OTP invalido", message);
                return;
            }

            Session.SignIn(profile);

            var targetRole = portal switch
            {
                "admin" => SGA.Web.Services.PortalRole.Admin,
                "operador" => SGA.Web.Services.PortalRole.Operator,
                "driver" => SGA.Web.Services.PortalRole.Driver,
                _ => SGA.Web.Services.PortalRole.None
            };

            if (!Session.CanAccess(targetRole))
            {
                Session.SignOut();
                message = "No tienes permiso para entrar a este portal.";
                Ui.ShowWarning("Sin permiso", message);
                return;
            }

            Navigation.NavigateTo(portal switch
            {
                "admin" => "/portal/admin",
                "operador" => "/portal/operador",
                "driver" => "/portal/driver",
                _ => "/acceso"
            });
        }
        catch (Exception ex)
        {
            message = ErrorHandler.Handle(ex, "No se pudo validar el OTP");
        }
    }

    private void ValidateEmail()
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            emailError = "Este campo es obligatorio.";
            return;
        }

        emailError = IsEmailFormatValid(email) ? null : "Formato de email invalido.";
    }

    private void ValidateOtp()
    {
        if (!showOtpStep && string.IsNullOrWhiteSpace(otpCode))
        {
            otpError = null;
            return;
        }

        if (string.IsNullOrWhiteSpace(otpCode))
        {
            otpError = "Este campo es obligatorio.";
            return;
        }

        var normalized = otpCode.Trim();
        otpError = normalized.Length == 6 && normalized.All(char.IsDigit)
            ? null
            : "Ingresa 6 digitos numericos.";
    }

    private void OnEmailInput()
    {
        ValidateEmail();
    }

    private void OnOtpInput()
    {
        ValidateOtp();
    }

    private static bool IsEmailFormatValid(string value)
    {
        var at = value.IndexOf('@');
        var dot = value.LastIndexOf('.');
        return at > 0 && dot > at + 1 && dot < value.Length - 1;
    }

    private static string GetInputCssClass(string? error)
        => string.IsNullOrWhiteSpace(error) ? "sga-input sga-input-valid" : "sga-input sga-input-invalid";

    private static string GetStatusCssClass(string? error)
        => string.IsNullOrWhiteSpace(error) ? "sga-field-hint success" : "sga-field-hint error";

    private static string GetStatusIcon(string? error, string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "⚠";
        }

        return string.IsNullOrWhiteSpace(error) ? "✓" : "✗";
    }

    private static string GetStatusText(string? error, string successText)
        => string.IsNullOrWhiteSpace(error) ? successText : error;

    private static string NormalizePortal(string? value)
    {
        var normalized = value?.Trim().ToLowerInvariant();
        return normalized is "admin" or "operador" or "driver" ? normalized : "admin";
    }
}