@page "/reservas"
@rendermode InteractiveServer
@inject SGA.Web.Services.SgaApiClient ApiClient
@inject IJSRuntime JS
@inject SGA.Web.Services.UiFeedbackService Ui

<section class="sga-section">
    <div>
        <h1>Centro de Reservas</h1>
        <p class="lead">Dos formas de reservar: rapida y guiada con ticket.</p>
    </div>

    <div class="sga-metrics-grid">
        <article class="sga-metric-card">
            <div class="sga-metric-icon">
                <img src="icons/nav/navigation.svg" alt="Reserva" />
            </div>
            <div>
                <span class="sga-metric-label">Reserva activa</span>
                <div class="sga-metric-value">@(reservationId > 0 ? reservationId : 0)</div>
                <p class="sga-metric-copy">ID en contexto para consulta y abordaje.</p>
            </div>
            <div class="sga-metric-actions">
                <a class="sga-btn alt" href="#section-actions">
                    <img src="icons/nav/eye.svg" alt="" />
                    Gestionar
                </a>
            </div>
        </article>

        <article class="sga-metric-card">
            <div class="sga-metric-icon">
                <img src="icons/nav/lock.svg" alt="Estado" />
            </div>
            <div>
                <span class="sga-metric-label">Estado</span>
                <div class="sga-metric-value">@CurrentStatus</div>
                <p class="sga-metric-copy">Estado actual de la reserva consultada.</p>
            </div>
            <div class="sga-metric-actions">
                <a class="sga-btn alt" href="#section-detail">
                    <img src="icons/nav/pencil.svg" alt="" />
                    Revisar
                </a>
            </div>
        </article>

        <article class="sga-metric-card">
            <div class="sga-metric-icon">
                <img src="icons/nav/plus.svg" alt="Ticket" />
            </div>
            <div>
                <span class="sga-metric-label">Ticket QR</span>
                <div class="sga-metric-value">@(ticket is null ? "No" : "Si")</div>
                <p class="sga-metric-copy">Disponibilidad para descarga de ticket y QR.</p>
            </div>
            <div class="sga-metric-actions">
                <a class="sga-btn alt" href="#section-ticket">
                    <img src="icons/nav/eye.svg" alt="" />
                    Ver ticket
                </a>
            </div>
        </article>
    </div>

    <div class="sga-two-col">
        <article class="sga-card">
            <div class="sga-card-header">
                <div>
                    <h3>Reserva rapida</h3>
                    <p class="sga-panel-note">Flujo rapido con IDs directos para operaciones internas.</p>
                </div>
            </div>
            <div class="sga-form-full single-col">
                <div class="sga-field">
                    <label>Trip ID</label>
                    <input @bind="quick.TripId" type="number" class="sga-input" />
                </div>

                <div class="sga-field">
                    <label>Person ID</label>
                    <input @bind="quick.PersonId" type="number" class="sga-input" />
                </div>

                <div class="sga-field">
                    <label>Authorization ID</label>
                    <input @bind="quick.AuthorizationId" type="number" class="sga-input" />
                </div>

                <div class="sga-field">
                    <label>Creado por</label>
                    <input @bind="quick.CreatedBy" class="sga-input" />
                </div>

                <button type="button" class="sga-btn" @onclick="CreateQuickReservationAsync">Reservar</button>
            </div>
        </article>

        <article class="sga-card">
            <div class="sga-card-header">
                <div>
                    <h3>Reserva guiada con ticket</h3>
                    <p class="sga-panel-note">Genera ticket y QR al confirmar la reserva.</p>
                </div>
            </div>
            <div class="sga-form-full single-col">
                <div class="sga-field">
                    <label>Trip ID</label>
                    <input @bind="guided.TripId" type="number" class="sga-input" />
                </div>

                <div class="sga-field">
                    <label>Person ID</label>
                    <input @bind="guided.PersonId" type="number" class="sga-input" />
                </div>

                <div class="sga-field">
                    <label>Authorization ID</label>
                    <input @bind="guided.AuthorizationId" type="number" class="sga-input" />
                </div>

                <div class="sga-field">
                    <label>Asiento sugerido</label>
                    <input @bind="guided.SeatCode" class="sga-input" />
                </div>

                <div class="sga-field">
                    <label>Creado por</label>
                    <input @bind="guided.CreatedBy" class="sga-input" />
                </div>

                <button type="button" class="sga-btn" @onclick="CreateGuidedReservationAsync">Reservar y generar ticket</button>
            </div>
        </article>
    </div>

    <article class="sga-card" id="section-actions">
        <div class="sga-card-header">
            <div>
                <h3>Acciones de reserva</h3>
                <p class="sga-panel-note">Consulta por ID o marca abordaje desde este bloque.</p>
            </div>
        </div>

        <div class="sga-inline-actions">
            <input @bind="reservationId" type="number" class="sga-input" placeholder="Reservation ID" />
            <input @bind="modifiedBy" class="sga-input" placeholder="Operador" />
            <button class="sga-btn alt" @onclick="GetReservationAsync">Consultar</button>
            <button class="sga-btn alt" @onclick="BoardReservationAsync">Marcar abordaje</button>
        </div>
    </article>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <p class="sga-alert">@message</p>
    }

    @if (reservation is not null)
    {
        <article class="sga-card" id="section-detail">
            <div class="sga-card-header">
                <div>
                    <h3>Reserva @reservation.Id</h3>
                    <p class="sga-panel-note">Detalle completo de la reserva en contexto.</p>
                </div>
                <span class="sga-status-pill">@reservation.Status</span>
            </div>
            <p>Viaje: @reservation.TripId</p>
            <p>Persona: @reservation.PersonId</p>
            <p>Autorizacion: @reservation.AuthorizationId</p>
            <p>Estado: @reservation.Status</p>
            <p>Cola: @reservation.QueueNumber</p>
            <p>QR: @reservation.QrCode</p>
        </article>
    }

    @if (ticket is not null)
    {
        <article class="sga-ticket" id="section-ticket">
            <div class="sga-ticket-header">
                <div class="sga-ticket-title">
                    <h3>Reserva Confirmada</h3>
                    <div class="sga-ticket-number">Reserva <strong>#@ticket.ReservationId</strong></div>
                </div>
                <span class="sga-ticket-status">Confirmado</span>
            </div>

            <div class="sga-ticket-grid">
                <div class="sga-ticket-item span-2">
                    <img src="icons/TRANSPORTE/route.svg" alt="Ruta" />
                    <div>
                        <span class="sga-ticket-label">Ruta</span>
                        <span class="sga-ticket-value">@(ticketTrip is null ? $"Viaje #{ticket.TripId}" : GetRouteLabel(ticketTrip))</span>
                    </div>
                </div>

                <div class="sga-ticket-item">
                    <img src="icons/TRANSPORTE/clock.svg" alt="Fecha" />
                    <div>
                        <span class="sga-ticket-label">Fecha del viaje</span>
                        <span class="sga-ticket-value">@(ticketTrip is null ? "N/D" : FormatLocalDateDate(ticketTrip.ScheduledDepartureTime))</span>
                    </div>
                </div>

                <div class="sga-ticket-item">
                    <img src="icons/TRANSPORTE/clock.svg" alt="Hora" />
                    <div>
                        <span class="sga-ticket-label">Hora de salida</span>
                        <span class="sga-ticket-value">@(ticketTrip is null ? "N/D" : FormatLocalTime(ticketTrip.ScheduledDepartureTime))</span>
                    </div>
                </div>

                <div class="sga-ticket-item">
                    <img src="icons/TRANSPORTE/bus.svg" alt="Bus" />
                    <div>
                        <span class="sga-ticket-label">Bus asignado</span>
                        <span class="sga-ticket-value">@(ticketTrip is null ? "Opcional" : $"Bus #{ticketTrip.BusId}")</span>
                    </div>
                </div>

                <div class="sga-ticket-item">
                    <img src="icons/nav/users.svg" alt="Turno" />
                    <div>
                        <span class="sga-ticket-label">Turno</span>
                        <span class="sga-ticket-value">@ticket.QueueNumber</span>
                    </div>
                </div>

                <div class="sga-ticket-item span-2">
                    <img src="icons/nav/shield.svg" alt="Código" />
                    <div>
                        <span class="sga-ticket-label">Código de reserva</span>
                        <span class="sga-ticket-value">@reservation?.QrCode</span>
                    </div>
                </div>
            </div>

            <div class="sga-ticket-qr">
                @if (!string.IsNullOrWhiteSpace(ticketQrBase64))
                {
                    <img alt="Código QR de abordaje" src="@($"data:image/png;base64,{ticketQrBase64}")" />
                }
                <p>Escanea este código al abordar</p>
                <div class="sga-ticket-actions">
                    <button type="button" class="sga-btn" @onclick="DownloadTicketAsync">Descargar ticket</button>
                    <button type="button" class="sga-btn alt" @onclick="DownloadQrAsync">Descargar QR</button>
                </div>
            </div>
        </article>
    }
</section>

@code {
    private ReservationForm quick = new();
    private GuidedReservationForm guided = new();
    private int reservationId;
    private string modifiedBy = "web-operator";
    private string? message;
    private SGA.Web.Models.ReservationResponse? reservation;
    private BoardingTicket? ticket;
    private SGA.Web.Models.TripResponse? ticketTrip;
    private string? ticketQrBase64;

    private string CurrentStatus => reservation?.Status ?? "-";

    private async Task CreateQuickReservationAsync()
    {
        using var busy = Ui.BeginBusy();
        message = null;
        ticket = null;
        ticketTrip = null;
        ticketQrBase64 = null;

        try
        {
            reservationId = await ApiClient.CreateReservationAsync(
                new SGA.Web.Models.CreateReservationRequest(quick.TripId, quick.PersonId, quick.AuthorizationId, quick.CreatedBy),
                CancellationToken.None);

            message = $"Reserva creada con ID {reservationId}.";
            Ui.ShowSuccess("Reserva creada", message);
            await GetReservationAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
            Ui.ShowError("No se pudo crear la reserva", ex.Message);
        }
    }

    private async Task CreateGuidedReservationAsync()
    {
        using var busy = Ui.BeginBusy();
        message = null;
        ticket = null;
        ticketTrip = null;
        ticketQrBase64 = null;

        try
        {
            reservationId = await ApiClient.CreateReservationAsync(
                new SGA.Web.Models.CreateReservationRequest(guided.TripId, guided.PersonId, guided.AuthorizationId, guided.CreatedBy),
                CancellationToken.None);

            await GetReservationAsync();

            if (reservation is not null)
            {
                ticket = new BoardingTicket(
                    reservation.Id,
                    reservation.TripId,
                    reservation.PersonId,
                    guided.SeatCode,
                    reservation.QueueNumber,
                    DateTime.UtcNow,
                    reservation.QrCode);

                ticketTrip = await ApiClient.GetTripByIdAsync(ticket.TripId, CancellationToken.None);
                ticketQrBase64 = GenerateQrBase64(ticket.QrValue);
            }

            message = $"Reserva guiada creada con ID {reservationId}. Ticket generado.";
            Ui.ShowSuccess("Ticket generado", message);
        }
        catch (Exception ex)
        {
            message = ex.Message;
            Ui.ShowError("No se pudo generar el ticket", ex.Message);
        }
    }

    private async Task GetReservationAsync()
    {
        using var busy = Ui.BeginBusy();
        message = null;
        if (reservationId <= 0)
        {
            message = "Ingresa un Reservation ID valido.";
            return;
        }

        try
        {
            reservation = await ApiClient.GetReservationByIdAsync(reservationId, CancellationToken.None);
            if (reservation is null)
            {
                message = "No se encontro la reserva.";
                Ui.ShowWarning("Reserva no encontrada", message);
            }
            else
            {
                Ui.ShowInfo("Reserva cargada", $"Reserva {reservation.Id} disponible para consulta.");
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
            Ui.ShowError("No se pudo consultar la reserva", ex.Message);
        }
    }

    private async Task BoardReservationAsync()
    {
        using var busy = Ui.BeginBusy();
        message = null;
        if (reservationId <= 0)
        {
            message = "Ingresa un Reservation ID valido.";
            return;
        }

        try
        {
            await ApiClient.BoardReservationAsync(new SGA.Web.Models.BoardReservationRequest(reservationId, modifiedBy), CancellationToken.None);
            message = "Reserva marcada como abordada.";
            Ui.ShowSuccess("Abordaje confirmado", message);
            await GetReservationAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
            Ui.ShowError("No se pudo marcar el abordaje", ex.Message);
        }
    }

    private sealed class ReservationForm
    {
        public int TripId { get; set; }
        public int PersonId { get; set; }
        public int AuthorizationId { get; set; }
        public string CreatedBy { get; set; } = "web-user";
    }

    private sealed class GuidedReservationForm
    {
        public int TripId { get; set; }
        public int PersonId { get; set; }
        public int AuthorizationId { get; set; }
        public string CreatedBy { get; set; } = "web-user";
        public string SeatCode { get; set; } = "A1";
    }

    private async Task DownloadTicketAsync()
    {
        if (ticket is null)
        {
            return;
        }

        ticketTrip ??= await ApiClient.GetTripByIdAsync(ticket.TripId, CancellationToken.None);

        var routeLabel = ticketTrip is null ? $"Viaje #{ticket.TripId}" : GetRouteLabel(ticketTrip);
        var departureDate = ticketTrip is null ? "N/D" : FormatLocalDateDate(ticketTrip.ScheduledDepartureTime);
        var departureTime = ticketTrip is null ? "N/D" : FormatLocalTime(ticketTrip.ScheduledDepartureTime);
        var busLabel = ticketTrip is null ? "Opcional" : $"Bus #{ticketTrip.BusId}";

        await JS.InvokeVoidAsync("sgaUi.downloadTicketPng", $"ticket-{ticket.ReservationId}.png", new
        {
            reservationId = ticket.ReservationId,
            route = routeLabel,
            departureDate,
            departureTime,
            bus = busLabel,
            queue = ticket.QueueNumber.ToString(),
            reservationCode = ticket.QrValue,
            qrBase64 = ticketQrBase64
        });

        Ui.ShowSuccess("Ticket descargado", "La imagen del ticket se descargo correctamente.");
    }

    private async Task DownloadQrAsync()
    {
        if (ticket is null || string.IsNullOrWhiteSpace(ticketQrBase64))
        {
            return;
        }

        await JS.InvokeVoidAsync("sgaUi.downloadBase64File", $"ticket-qr-{ticket.ReservationId}.png", "image/png", ticketQrBase64);
        Ui.ShowSuccess("QR descargado", "La imagen QR se descargo correctamente.");
    }

    private static string GenerateQrBase64(string qrValue)
    {
        using var generator = new QRCoder.QRCodeGenerator();
        using var data = generator.CreateQrCode(qrValue, QRCoder.QRCodeGenerator.ECCLevel.Q);
        var qrCode = new QRCoder.PngByteQRCode(data);
        var bytes = qrCode.GetGraphic(20);
        return Convert.ToBase64String(bytes);
    }

    private static string BuildBoardingTicketHtml(
        BoardingTicket ticket,
        SGA.Web.Models.TripResponse? trip,
        string? qrBase64)
    {
        var routeLabel = trip is null ? $"Viaje #{ticket.TripId}" : GetRouteLabel(trip);
        var departureDate = trip is null ? "N/D" : FormatLocalDateDate(trip.ScheduledDepartureTime);
        var departureTime = trip is null ? "N/D" : FormatLocalTime(trip.ScheduledDepartureTime);
        var busLabel = trip is null ? "Opcional" : $"Bus #{trip.BusId}";
        var qrImage = string.IsNullOrWhiteSpace(qrBase64)
            ? string.Empty
            : $"<img alt='Código QR de abordaje' style='width:180px;height:180px;border:1px solid #d1d5db;border-radius:12px;padding:10px;background:#fff;' src='data:image/png;base64,{qrBase64}' />";

        return $@"<!doctype html>
<html lang='es'>
<head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>Reserva {ticket.ReservationId}</title>
    <style>
        body {{ margin: 0; font-family: Segoe UI, Arial, sans-serif; background: #f4f7fb; color: #1f2937; padding: 24px; }}
        .ticket {{ max-width: 760px; margin: 0 auto; background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; box-shadow: 0 14px 34px rgba(15, 23, 42, 0.08); overflow: hidden; }}
        .head {{ padding: 24px; border-bottom: 1px solid #e5e7eb; display: flex; justify-content: space-between; gap: 16px; align-items: start; }}
        .title {{ display: grid; gap: 6px; }}
        .title h1 {{ margin: 0; font-size: 24px; color: #005f73; }}
        .number {{ font-size: 14px; color: #64748b; }}
        .number strong {{ color: #111827; font-size: 16px; }}
        .badge {{ padding: 8px 12px; border-radius: 999px; background: rgba(31,143,95,.12); color: #1f8f5f; font-size: 12px; font-weight: 800; }}
        .grid {{ padding: 24px; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }}
        .item {{ display: flex; gap: 10px; padding: 14px 16px; background: #fafafa; border: 1px solid #edf2f7; border-radius: 8px; }}
        .item.full {{ grid-column: 1 / -1; }}
        .label {{ display: block; margin-bottom: 4px; font-size: 11px; text-transform: uppercase; letter-spacing: .04em; color: #64748b; font-weight: 700; }}
        .value {{ font-size: 15px; font-weight: 700; color: #111827; line-height: 1.35; }}
        .qr {{ padding: 0 24px 24px; display: grid; gap: 12px; justify-items: center; text-align: center; }}
        .qr img {{ width: 180px; height: 180px; border: 1px solid #d1d5db; border-radius: 12px; padding: 10px; background: #fff; }}
        .qr p {{ margin: 0; color: #64748b; font-size: 13px; }}
        @media print {{ body {{ background: #fff; padding: 0; }} .ticket {{ box-shadow: none; border: 0; }} }}
    </style>
</head>
<body>
    <section class='ticket'>
        <div class='head'>
            <div class='title'>
                <h1>Reserva Confirmada</h1>
                <div class='number'>Reserva <strong>#{ticket.ReservationId}</strong></div>
            </div>
            <div class='badge'>Confirmado</div>
        </div>
        <div class='grid'>
            <div class='item full'><div><span class='label'>Ruta</span><span class='value'>{EscapeHtml(routeLabel)}</span></div></div>
            <div class='item'><div><span class='label'>Fecha del viaje</span><span class='value'>{departureDate}</span></div></div>
            <div class='item'><div><span class='label'>Hora de salida</span><span class='value'>{departureTime}</span></div></div>
            <div class='item'><div><span class='label'>Bus asignado</span><span class='value'>{EscapeHtml(busLabel)}</span></div></div>
            <div class='item'><div><span class='label'>Turno</span><span class='value'>{ticket.QueueNumber}</span></div></div>
            <div class='item full'><div><span class='label'>Código de reserva</span><span class='value'>{EscapeHtml(ticket.QrValue)}</span></div></div>
        </div>
        <div class='qr'>
            {qrImage}
            <p>Escanea este código al abordar</p>
        </div>
    </section>
</body>
</html>";
    }

    private static string GetRouteLabel(SGA.Web.Models.TripResponse trip)
        => string.IsNullOrWhiteSpace(trip.RouteName) ? $"Ruta ID {trip.RouteId}" : trip.RouteName;

    private static string FormatLocalDateDate(DateTime value)
        => value.ToLocalTime().ToString("dd/MM/yyyy");

    private static string FormatLocalTime(DateTime value)
        => value.ToLocalTime().ToString("hh:mm tt");

    private static string EscapeHtml(string value)
        => System.Net.WebUtility.HtmlEncode(value);

    private sealed record BoardingTicket(
        int ReservationId,
        int TripId,
        int PersonId,
        string SeatCode,
        int QueueNumber,
        DateTime GeneratedAt,
        string QrValue);
}
