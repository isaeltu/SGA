@page "/portal/admin"
@rendermode InteractiveServer
@inject SGA.Web.Services.SgaApiClient ApiClient
@inject SGA.Web.Services.PortalSessionService Session
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject SGA.Web.Services.UiFeedbackService Ui

<section class="sga-section">
    <div>
        <h1>Portal Administrador</h1>
        <p class="lead">Gestiona instituciones, roles, permisos y usuarios con un panel limpio y directo.</p>
    </div>

    <div class="sga-metrics-grid">
        <article class="sga-metric-card">
            <div class="sga-metric-icon">
                <img src="icons/nav/building.svg" alt="Instituciones" />
            </div>
            <div>
                <span class="sga-metric-label">Instituciones</span>
                <div class="sga-metric-value">@institutions.Count</div>
                <p class="sga-metric-copy">Instituciones activas y cargadas en la sesión actual.</p>
            </div>
            <div class="sga-metric-actions">
                <a class="sga-btn alt" href="#section-institutions">
                    <img src="icons/nav/plus.svg" alt="" />
                    Administrar
                </a>
            </div>
        </article>

        <article class="sga-metric-card">
            <div class="sga-metric-icon">
                <img src="icons/nav/shield.svg" alt="Roles" />
            </div>
            <div>
                <span class="sga-metric-label">Roles</span>
                <div class="sga-metric-value">@RoleCount</div>
                <p class="sga-metric-copy">Perfiles base disponibles para controlar el acceso.</p>
            </div>
            <div class="sga-metric-actions">
                <a class="sga-btn alt" href="#section-roles">
                    <img src="icons/nav/eye.svg" alt="" />
                    Ver roles
                </a>
            </div>
        </article>

        <article class="sga-metric-card">
            <div class="sga-metric-icon">
                <img src="icons/nav/lock.svg" alt="Permisos" />
            </div>
            <div>
                <span class="sga-metric-label">Permisos</span>
                <div class="sga-metric-value">@PermissionCount</div>
                <p class="sga-metric-copy">Permisos recomendados para el ecosistema SGA-ITLA.</p>
            </div>
            <div class="sga-metric-actions">
                <a class="sga-btn alt" href="#section-permissions">
                    <img src="icons/nav/eye.svg" alt="" />
                    Ver permisos
                </a>
            </div>
        </article>

        <article class="sga-metric-card">
            <div class="sga-metric-icon">
                <img src="icons/nav/user.svg" alt="Drivers" />
            </div>
            <div>
                <span class="sga-metric-label">Drivers</span>
                <div class="sga-metric-value">@drivers.Count</div>
                <p class="sga-metric-copy">Drivers registrados para operar la flota institucional.</p>
            </div>
            <div class="sga-metric-actions">
                <a class="sga-btn alt" href="#section-drivers">
                    <img src="icons/nav/plus.svg" alt="" />
                    Gestionar
                </a>
            </div>
        </article>
    </div>

    <div class="sga-two-col">
        <article class="sga-card" id="section-institutions">
            <h3>Crear institucion</h3>
            <div class="sga-form-grid compact">
                <label>Codigo</label>
                <input @bind="institutionCode" class="sga-input" />

                <label>Nombre</label>
                <input @bind="institutionName" class="sga-input" />

                <label>Creado por</label>
                <input @bind="createdBy" class="sga-input" />

                <button class="sga-btn" @onclick="CreateInstitutionAsync">Crear institucion</button>
            </div>
        </article>

        <article class="sga-card" id="section-roles">
            <h3>Crear rol</h3>
            <div class="sga-form-grid compact">
                <label>Nombre del rol</label>
                <input @bind="roleName" class="sga-input" />

                <label>Descripcion</label>
                <input @bind="roleDescription" class="sga-input" />

                <label>Creado por</label>
                <input @bind="createdBy" class="sga-input" />

                <button class="sga-btn" @onclick="CreateRoleAsync">Crear rol</button>
            </div>
        </article>

        <article class="sga-card" id="section-permissions">
            <h3>Crear permiso</h3>
            <div class="sga-form-grid compact">
                <label>Nombre del permiso</label>
                <input @bind="permissionName" class="sga-input" />

                <label>Descripcion</label>
                <input @bind="permissionDescription" class="sga-input" />

                <label>Creado por</label>
                <input @bind="createdBy" class="sga-input" />

                <button class="sga-btn alt" @onclick="CreatePermissionAsync">Crear permiso</button>
            </div>
        </article>
    </div>

    <article class="sga-card" id="section-drivers">
        <h3>Agregar driver de la organizacion</h3>
        <p>Este flujo esta pensado para registrar drivers rapidamente en la institucion del administrador.</p>

        <div class="sga-form-grid compact">
            @if (Session.IsMasterAdmin)
            {
                <label>Institucion ID</label>
                <input class="sga-input" type="number" @bind="quickDriver.InstitutionId" />
            }
            else
            {
                <label>Institucion</label>
                <input class="sga-input" value="@Session.InstitutionId" readonly />
            }

            <label>Nombre</label>
            <input class="sga-input" @bind="quickDriver.FirstName" />

            <label>Apellido</label>
            <input class="sga-input" @bind="quickDriver.LastName" />

            <label>Correo</label>
            <input class="sga-input" type="email" @bind="quickDriver.Email" />

            <label>Telefono</label>
            <input class="sga-input" @bind="quickDriver.PhoneNumber" />

            <label>Cedula</label>
            <input class="sga-input" @bind="quickDriver.Cedula" />

            <label>Licencia</label>
            <input class="sga-input" @bind="quickDriver.DriverLicense" />

            <label>Vencimiento licencia</label>
            <input class="sga-input" type="date" @bind="quickDriver.DriverLicenseExpiryDate" />

            <button class="sga-btn alt" @onclick="CreateOrganizationDriverAsync">Agregar driver</button>
        </div>
    </article>

    <article class="sga-card">
        <h3>Registrar usuario por tipo</h3>
        <div class="sga-form-grid compact">
            <label>Tipo de usuario</label>
            <select class="sga-input" @bind="userType">
                @if (Session.IsMasterAdmin)
                {
                    <option value="administrator">Administrador</option>
                    <option value="operator">Operador</option>
                    <option value="driver">Driver</option>
                }
                else
                {
                    <option value="operator">Operador</option>
                    <option value="driver">Driver</option>
                }
            </select>

            @if (Session.IsMasterAdmin)
            {
                <label>Institucion ID</label>
                <input class="sga-input" type="number" @bind="newUser.InstitutionId" />
            }
            else
            {
                <label>Institucion asignada</label>
                <input class="sga-input" value="@Session.InstitutionId" readonly />
            }

            <label>Nombre</label>
            <input class="sga-input" @bind="newUser.FirstName" />

            <label>Apellido</label>
            <input class="sga-input" @bind="newUser.LastName" />

            <label>Correo</label>
            <input class="sga-input" type="email" @bind="newUser.Email" />

            <label>Telefono (10 digitos)</label>
            <input class="sga-input" @bind="newUser.PhoneNumber" />

            <label>Cedula</label>
            <input class="sga-input" @bind="newUser.Cedula" />

            @if (userType == "operator")
            {
                <label>Area asignada</label>
                <input class="sga-input" @bind="newUser.AssignedArea" />
                <label>Turno</label>
                <input class="sga-input" type="number" @bind="newUser.ShiftNumber" />
            }

            @if (userType == "driver")
            {
                <label>Licencia</label>
                <input class="sga-input" @bind="newUser.DriverLicense" />
                <label>Vencimiento licencia</label>
                <input class="sga-input" type="date" @bind="newUser.DriverLicenseExpiryDate" />
            }

            @if (userType == "administrator")
            {
                <label>Nivel admin (1=SuperAdmin, 2=Admin, 3=Moderator)</label>
                <input class="sga-input" type="number" @bind="newUser.AdminLevel" />
            }

            <label>Creado por</label>
            <input class="sga-input" @bind="createdBy" />

            <button class="sga-btn" @onclick="RegisterUserAsync">Registrar usuario</button>
        </div>
    </article>

    <article class="sga-card">
        <h3>Instituciones registradas</h3>
        <p>Puedes cargar el listado completo para validar IDs y nombres antes de crear usuarios.</p>
        <div class="sga-inline-actions operator-actions">
            <button class="sga-btn alt" @onclick="LoadInstitutionsAsync">Obtener todas las instituciones</button>
            <input class="sga-input" type="number" @bind="selectedInstitutionId" placeholder="Institution ID" />
            <button class="sga-btn alt" @onclick="LoadInstitutionByIdAsync">Buscar por ID</button>
            <button class="sga-btn danger" @onclick="DeleteSelectedInstitutionAsync">Eliminar seleccionada</button>
        </div>

        @if (institutions.Count > 0)
        {
            <table class="sga-table" style="margin-top:1rem;">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Codigo</th>
                        <th>Nombre</th>
                        <th>Activa</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var institution in institutions)
                    {
                        <tr @onclick="() => SelectInstitution(institution)">
                            <td>@institution.Id</td>
                            <td>@institution.Code</td>
                            <td>@institution.Name</td>
                            <td>@(institution.IsActive ? "Si" : "No")</td>
                            <td>
                                <div class="sga-row-actions">
                                    <button type="button" class="sga-icon-btn alt" @onclick:stopPropagation="true" @onclick="() => SelectInstitution(institution)" title="Ver institucion">
                                        <img src="icons/nav/eye.svg" alt="" />
                                    </button>
                                    <button type="button" class="sga-icon-btn alt" @onclick:stopPropagation="true" @onclick="() => SelectInstitution(institution)" title="Editar institucion">
                                        <img src="icons/nav/pencil.svg" alt="" />
                                    </button>
                                    <button type="button" class="sga-icon-btn danger" @onclick:stopPropagation="true" @onclick="() => DeleteInstitutionAsync(institution.Id)" title="Eliminar institucion">
                                        <img src="icons/nav/trash.svg" alt="" />
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="sga-empty" style="margin-top:1rem;">No hay instituciones cargadas. Usa el boton de consulta o crea una nueva.</div>
        }

        @if (selectedInstitutionId > 0)
        {
            <div class="sga-form-grid compact" style="margin-top:1rem;">
                <label>Codigo (edicion)</label>
                <input class="sga-input" @bind="institutionEditCode" />
                <label>Nombre (edicion)</label>
                <input class="sga-input" @bind="institutionEditName" />
                <label>Activa</label>
                <input class="sga-input" type="checkbox" @bind="institutionEditIsActive" />
                <button class="sga-btn alt" @onclick="UpdateSelectedInstitutionAsync">Actualizar institucion</button>
            </div>
        }
    </article>

    <article class="sga-card">
        <h3>Buses registrados</h3>
        <div class="sga-inline-actions operator-actions">
            <button class="sga-btn alt" @onclick="LoadBusesAsync">Obtener todos los buses</button>
            <input class="sga-input" type="number" @bind="selectedBusId" placeholder="Bus ID" />
            <button class="sga-btn alt" @onclick="LoadBusByIdAsync">Buscar por ID</button>
            <button class="sga-btn danger" @onclick="DeleteSelectedBusAsync">Eliminar seleccionado</button>
        </div>

        @if (buses.Count > 0)
        {
            <table class="sga-table" style="margin-top:1rem;">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Institucion</th>
                        <th>Placa</th>
                        <th>Modelo</th>
                        <th>Anio</th>
                        <th>Capacidad</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var bus in buses)
                    {
                        <tr @onclick="() => SelectBus(bus)">
                            <td>@bus.Id</td>
                            <td>@bus.InstitutionId</td>
                            <td>@bus.LicensePlate</td>
                            <td>@bus.Model</td>
                            <td>@bus.Year</td>
                            <td>@bus.Capacity</td>
                            <td>
                                <div class="sga-row-actions">
                                    <button type="button" class="sga-icon-btn alt" @onclick:stopPropagation="true" @onclick="() => SelectBus(bus)" title="Ver bus">
                                        <img src="icons/nav/eye.svg" alt="" />
                                    </button>
                                    <button type="button" class="sga-icon-btn alt" @onclick:stopPropagation="true" @onclick="() => SelectBus(bus)" title="Editar bus">
                                        <img src="icons/nav/pencil.svg" alt="" />
                                    </button>
                                    <button type="button" class="sga-icon-btn danger" @onclick:stopPropagation="true" @onclick="() => DeleteBusAsync(bus.Id)" title="Eliminar bus">
                                        <img src="icons/nav/trash.svg" alt="" />
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="sga-empty" style="margin-top:1rem;">No hay buses cargados en el listado actual.</div>
        }

        @if (selectedBusId > 0)
        {
            <div class="sga-form-grid compact" style="margin-top:1rem;">
                <label>Institucion ID</label>
                <input class="sga-input" type="number" @bind="busEditInstitutionId" />
                <label>Placa</label>
                <input class="sga-input" @bind="busEditLicensePlate" />
                <label>Modelo</label>
                <input class="sga-input" @bind="busEditModel" />
                <label>Anio</label>
                <input class="sga-input" type="number" @bind="busEditYear" />
                <label>Capacidad</label>
                <input class="sga-input" type="number" @bind="busEditCapacity" />
                <button class="sga-btn alt" @onclick="UpdateSelectedBusAsync">Actualizar bus</button>
            </div>
        }
    </article>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <p class="sga-alert">@message</p>
    }

    <article class="sga-card">
        <h3>Permisos recomendados por rol</h3>
        <div class="permission-grid">
            <div>
                <h4>Administrador</h4>
                <ul>
                    <li>roles.create</li>
                    <li>permissions.create</li>
                    <li>institutions.manage</li>
                    <li>users.manage</li>
                </ul>
            </div>
            <div>
                <h4>Operador</h4>
                <ul>
                    <li>trips.create</li>
                    <li>trips.update</li>
                    <li>reservations.board</li>
                    <li>trips.monitor</li>
                </ul>
            </div>
            <div>
                <h4>Driver</h4>
                <ul>
                    <li>trips.start</li>
                    <li>trips.complete</li>
                    <li>incidents.report</li>
                </ul>
            </div>
            <div>
                <h4>Cliente y Estudiante</h4>
                <ul>
                    <li>reservations.create</li>
                    <li>trips.read.available</li>
                </ul>
            </div>
        </div>
    </article>
</section>

@code {
    private const int RoleCount = 4;
    private const int PermissionCount = 13;

    private string institutionCode = string.Empty;
    private string institutionName = string.Empty;
    private string roleName = string.Empty;
    private string? roleDescription;
    private string permissionName = string.Empty;
    private string? permissionDescription;
    private string createdBy = "web-admin";
    private string userType = "operator";
    private readonly NewUserForm newUser = new();
    private readonly QuickDriverForm quickDriver = new();
    private List<SGA.Web.Models.InstitutionResponse> institutions = new();
    private List<SGA.Web.Models.DriverLookupResponse> drivers = new();
    private List<SGA.Web.Models.BusResponse> buses = new();
    private int selectedInstitutionId;
    private string institutionEditCode = string.Empty;
    private string institutionEditName = string.Empty;
    private bool institutionEditIsActive = true;
    private int selectedBusId;
    private int busEditInstitutionId;
    private string busEditLicensePlate = string.Empty;
    private string busEditModel = string.Empty;
    private int busEditYear = DateTime.Today.Year;
    private int busEditCapacity = 40;
    private string? message;
    private bool redirectToLogin;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.CanAccess(SGA.Web.Services.PortalRole.Admin))
        {
            redirectToLogin = true;
            return;
        }

        if (!Session.IsMasterAdmin)
        {
            newUser.InstitutionId = Session.InstitutionId;
            userType = "operator";
        }

        await LoadSummaryAsync();
    }

    private async Task LoadSummaryAsync()
    {
        using var busy = Ui.BeginBusy();

        try
        {
            var institutionResponse = await ApiClient.GetInstitutionsAsync(CancellationToken.None);
            institutions = institutionResponse?.OrderBy(x => x.Name).ToList() ?? new List<SGA.Web.Models.InstitutionResponse>();
        }
        catch
        {
            institutions = new List<SGA.Web.Models.InstitutionResponse>();
        }

        try
        {
            var driverResponse = await ApiClient.GetDriversAsync(Session.IsMasterAdmin ? null : Session.InstitutionId, false, CancellationToken.None);
            drivers = driverResponse?.OrderBy(driver => driver.FullName).ToList() ?? new List<SGA.Web.Models.DriverLookupResponse>();
        }
        catch
        {
            drivers = new List<SGA.Web.Models.DriverLookupResponse>();
        }
    }

    private async Task CreateOrganizationDriverAsync()
    {
        using var busy = Ui.BeginBusy();
        message = null;

        var institutionId = Session.IsMasterAdmin
            ? quickDriver.InstitutionId
            : Session.InstitutionId;

        if (institutionId <= 0 ||
            string.IsNullOrWhiteSpace(quickDriver.FirstName) ||
            string.IsNullOrWhiteSpace(quickDriver.LastName) ||
            string.IsNullOrWhiteSpace(quickDriver.Email) ||
            string.IsNullOrWhiteSpace(quickDriver.PhoneNumber) ||
            string.IsNullOrWhiteSpace(quickDriver.Cedula) ||
            string.IsNullOrWhiteSpace(quickDriver.DriverLicense))
        {
            message = "Completa los datos del driver para continuar.";
            return;
        }

        try
        {
            var roleId = await ApiClient.CreateRoleAsync(
                new SGA.Web.Models.CreateRoleRequest("Driver", "Rol de Driver", createdBy),
                CancellationToken.None);

            var personId = await ApiClient.CreatePersonAsync(
                new SGA.Web.Models.CreatePersonRequest(
                    institutionId,
                    roleId,
                    quickDriver.Email.Trim(),
                    quickDriver.PhoneNumber.Trim(),
                    quickDriver.FirstName.Trim(),
                    quickDriver.LastName.Trim(),
                    quickDriver.Cedula.Trim(),
                    createdBy),
                CancellationToken.None);

            var driverId = await ApiClient.CreateDriverUserAsync(
                new SGA.Web.Models.CreateDriverUserRequest(
                    personId,
                    quickDriver.DriverLicense.Trim(),
                    new DateTimeOffset(quickDriver.DriverLicenseExpiryDate.Date, TimeSpan.Zero),
                    createdBy),
                CancellationToken.None);

            message = $"Driver registrado correctamente con ID {driverId}.";
            Ui.ShowSuccess("Driver creado", message);
        }
        catch (Exception ex)
        {
            message = ex.Message;
            Ui.ShowError("No se pudo crear el driver", ex.Message);
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && redirectToLogin)
        {
            Navigation.NavigateTo("/login-portal?portal=admin");
        }

        return Task.CompletedTask;
    }

    private async Task CreateRoleAsync()
    {
        using var busy = Ui.BeginBusy();
        message = null;
        if (string.IsNullOrWhiteSpace(roleName))
        {
            message = "El nombre del rol es obligatorio.";
            return;
        }

        try
        {
            var id = await ApiClient.CreateRoleAsync(new SGA.Web.Models.CreateRoleRequest(roleName, roleDescription, createdBy), CancellationToken.None);
            message = $"Rol creado con ID {id}.";
            Ui.ShowSuccess("Rol creado", message);
            roleName = string.Empty;
            roleDescription = string.Empty;
        }
        catch (Exception ex)
        {
            message = ex.Message;
            Ui.ShowError("No se pudo crear el rol", ex.Message);
        }
    }

    private async Task CreateInstitutionAsync()
    {
        using var busy = Ui.BeginBusy();
        message = null;
        if (string.IsNullOrWhiteSpace(institutionCode) || string.IsNullOrWhiteSpace(institutionName))
        {
            message = "El codigo y nombre de institucion son obligatorios.";
            return;
        }

        try
        {
            var id = await ApiClient.CreateInstitutionAsync(
                new SGA.Web.Models.CreateInstitutionRequest(
                    institutionCode.Trim(),
                    institutionName.Trim(),
                    createdBy),
                CancellationToken.None);

            message = $"Institucion creada con ID {id}.";
            Ui.ShowSuccess("Institucion creada", message);
            institutionCode = string.Empty;
            institutionName = string.Empty;
            await LoadInstitutionsAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
            Ui.ShowError("No se pudo crear la institucion", ex.Message);
        }
    }

    private async Task CreatePermissionAsync()
    {
        using var busy = Ui.BeginBusy();
        message = null;
        if (string.IsNullOrWhiteSpace(permissionName))
        {
            message = "El nombre del permiso es obligatorio.";
            return;
        }

        try
        {
            var id = await ApiClient.CreatePermissionAsync(new SGA.Web.Models.CreatePermissionRequest(permissionName, permissionDescription, createdBy), CancellationToken.None);
            message = $"Permiso creado con ID {id}.";
            Ui.ShowSuccess("Permiso creado", message);
            permissionName = string.Empty;
            permissionDescription = string.Empty;
        }
        catch (Exception ex)
        {
            message = ex.Message;
            Ui.ShowError("No se pudo crear el permiso", ex.Message);
        }
    }

    private async Task RegisterUserAsync()
    {
        using var busy = Ui.BeginBusy();
        message = null;

        if (!Session.IsMasterAdmin)
        {
            if (userType is not ("operator" or "driver"))
            {
                message = "Un administrador regular solo puede crear operadores o drivers.";
                return;
            }

            newUser.InstitutionId = Session.InstitutionId;
        }

        if (newUser.InstitutionId <= 0 ||
            string.IsNullOrWhiteSpace(newUser.FirstName) ||
            string.IsNullOrWhiteSpace(newUser.LastName) ||
            string.IsNullOrWhiteSpace(newUser.Email) ||
            string.IsNullOrWhiteSpace(newUser.PhoneNumber) ||
            string.IsNullOrWhiteSpace(newUser.Cedula))
        {
            message = "Completa los datos base del usuario.";
            return;
        }

        try
        {
            var roleNameForType = userType switch
            {
                "administrator" => "Administrador",
                "operator" => "Operador",
                "driver" => "Driver",
                _ => "Operador"
            };

            var roleId = await ApiClient.CreateRoleAsync(
                new SGA.Web.Models.CreateRoleRequest(roleNameForType, $"Rol de {roleNameForType}", createdBy),
                CancellationToken.None);

            var personId = await ApiClient.CreatePersonAsync(
                new SGA.Web.Models.CreatePersonRequest(
                    newUser.InstitutionId,
                    roleId,
                    newUser.Email.Trim(),
                    newUser.PhoneNumber.Trim(),
                    newUser.FirstName.Trim(),
                    newUser.LastName.Trim(),
                    newUser.Cedula.Trim(),
                    createdBy),
                CancellationToken.None);

            switch (userType)
            {
                case "operator":
                    await ApiClient.CreateOperatorUserAsync(
                        new SGA.Web.Models.CreateOperatorUserRequest(
                            personId,
                            string.IsNullOrWhiteSpace(newUser.AssignedArea) ? "Operaciones" : newUser.AssignedArea,
                            newUser.ShiftNumber <= 0 ? 1 : newUser.ShiftNumber,
                            createdBy),
                        CancellationToken.None);
                    break;
                case "driver":
                    await ApiClient.CreateDriverUserAsync(
                        new SGA.Web.Models.CreateDriverUserRequest(
                            personId,
                            string.IsNullOrWhiteSpace(newUser.DriverLicense) ? "LIC-NA" : newUser.DriverLicense,
                            new DateTimeOffset(newUser.DriverLicenseExpiryDate.Date, TimeSpan.Zero),
                            createdBy),
                        CancellationToken.None);
                    break;
                case "administrator":
                    if (!Session.IsMasterAdmin)
                    {
                        message = "Solo el administrador master puede crear administradores.";
                        return;
                    }

                    await ApiClient.CreateAdministratorUserAsync(
                        new SGA.Web.Models.CreateAdministratorUserRequest(
                            personId,
                            newUser.AdminLevel is < 1 or > 3 ? 2 : newUser.AdminLevel,
                            createdBy),
                        CancellationToken.None);
                    break;
            }

            message = $"Usuario registrado correctamente con Person ID {personId}.";
            Ui.ShowSuccess("Usuario registrado", message);
        }
        catch (Exception ex)
        {
            message = ex.Message;
            Ui.ShowError("No se pudo registrar el usuario", ex.Message);
        }
    }

