@page "/portal/operador"
@rendermode InteractiveServer
@inject SGA.Web.Services.SgaApiClient ApiClient
@inject SGA.Web.Services.PortalSessionService Session
@inject NavigationManager Navigation

<section class="sga-section">
    <h1>Portal Operador</h1>
    <p class="lead">Gestiona buses, rutas y viajes para que los clientes reserven con informacion clara.</p>

    <div class="sga-form-grid">
        <label>Institucion de trabajo</label>
        @if (Session.InstitutionId > 0)
        {
            <input class="sga-input" value="@institutionLabel" readonly />
        }
        else
        {
            <select class="sga-input" @bind="selectedInstitutionId" @bind:after="OnInstitutionChangedAsync">
                <option value="0">Selecciona una institucion</option>
                @foreach (var institution in institutions)
                {
                    <option value="@institution.Id">@institution.Name (@institution.Code)</option>
                }
            </select>
        }
    </div>

    <article class="sga-card">
        <h3>Crear autobus</h3>
        <div class="sga-form-grid compact">
            <label>Placa</label>
            <input @bind="busModel.LicensePlate" class="sga-input" />

            <label>Modelo</label>
            <input @bind="busModel.Model" class="sga-input" />

            <label>Anio</label>
            <input @bind="busModel.Year" type="number" class="sga-input" />

            <label>Capacidad</label>
            <input @bind="busModel.Capacity" type="number" class="sga-input" />

            <button class="sga-btn alt" @onclick="CreateBusAsync">Registrar autobus</button>
        </div>

        @if (buses.Count > 0)
        {
            <table class="sga-table" style="margin-top:1rem;">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Placa</th>
                        <th>Modelo</th>
                        <th>Capacidad</th>
                        <th>Accion</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var bus in buses)
                    {
                        <tr>
                            <td>@bus.Id</td>
                            <td>@bus.LicensePlate</td>
                            <td>@bus.Model</td>
                            <td>@bus.Capacity</td>
                            <td>
                                <button class="sga-btn danger" @onclick="() => DeleteBusAsync(bus.Id)">Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="sga-empty">No hay buses registrados para esta institucion.</div>
        }
    </article>

    <article class="sga-card">
        <h3>Crear ruta</h3>
        <div class="sga-form-grid compact">
            <label>Nombre de ruta</label>
            <input @bind="routeModel.Name" class="sga-input" />

            <label>Origen</label>
            <input @bind="routeModel.Origin" class="sga-input" />

            <label>Destino</label>
            <input @bind="routeModel.Destination" class="sga-input" />

            <label>Distancia (km)</label>
            <input @bind="routeModel.DistanceKm" type="number" step="0.1" class="sga-input" />

            <label>Duracion estimada (min)</label>
            <input @bind="routeModel.EstimatedDurationMinutes" type="number" class="sga-input" />

            <button class="sga-btn alt" @onclick="CreateRouteAsync">Registrar ruta</button>
        </div>

        <div class="sga-form-grid compact" style="margin-top:1rem;">
            <label>Ruta seleccionada para editar</label>
            <select class="sga-input" @bind="selectedRouteId" @bind:after="LoadSelectedRouteForEditAsync">
                <option value="0">Selecciona una ruta</option>
                @foreach (var route in routes)
                {
                    <option value="@route.Id">@route.Name (@route.Origin -> @route.Destination)</option>
                }
            </select>

            @if (selectedRouteId > 0)
            {
                <label>Nombre (edicion)</label>
                <input @bind="routeEditModel.Name" class="sga-input" />

                <label>Origen (edicion)</label>
                <input @bind="routeEditModel.Origin" class="sga-input" />

                <label>Destino (edicion)</label>
                <input @bind="routeEditModel.Destination" class="sga-input" />

                <label>Distancia (km)</label>
                <input @bind="routeEditModel.DistanceKm" type="number" step="0.1" class="sga-input" />

                <label>Duracion estimada (min)</label>
                <input @bind="routeEditModel.EstimatedDurationMinutes" type="number" class="sga-input" />

                <label>Activa</label>
                <input @bind="routeEditModel.IsActive" type="checkbox" class="sga-input" />

                <button class="sga-btn alt" @onclick="UpdateRouteAsync">Actualizar ruta</button>
                <button class="sga-btn danger" @onclick="DeleteSelectedRouteAsync">Eliminar ruta</button>
            }
        </div>

        <div class="sga-inline-actions operator-actions" style="margin-top:1rem;">
            <button class="sga-btn alt" @onclick="LoadRoutesAsync">Recargar rutas</button>
            <span>Total rutas: @routes.Count</span>
        </div>

        @if (routes.Count > 0)
        {
            <table class="sga-table" style="margin-top:1rem;">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Origen</th>
                        <th>Destino</th>
                        <th>Activa</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var route in routes)
                    {
                        <tr>
                            <td>@route.Id</td>
                            <td>@route.Name</td>
                            <td>@route.Origin</td>
                            <td>@route.Destination</td>
                            <td>@(route.IsActive ? "Si" : "No")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="sga-empty">No hay rutas disponibles. Crea una ruta para habilitar viajes.</div>
        }
    </article>

    <article class="sga-card">
        <h3>Crear viaje</h3>
        <div class="sga-form-grid compact">
            <label>Ruta</label>
            <select class="sga-input" @bind="createModel.RouteId">
                <option value="0">Selecciona una ruta</option>
                @foreach (var route in routes)
                {
                    <option value="@route.Id">@route.Name (@route.Origin -> @route.Destination)</option>
                }
            </select>

            <label>Driver ID</label>
            <input @bind="createModel.DriverId" type="number" class="sga-input" />

            <label>Drivers disponibles</label>
            <div class="sga-inline-actions operator-actions">
                <select class="sga-input" @bind="selectedDriverId">
                    <option value="0">Selecciona un driver</option>
                    @foreach (var driver in drivers)
                    {
                        <option value="@driver.DriverId">@driver.FullName - @driver.DriverLicense</option>
                    }
                </select>
                <button class="sga-btn alt" @onclick="LoadDriversAsync">Cargar drivers</button>
                <button class="sga-btn alt" @onclick="ApplySelectedDriver">Autocompletar Driver ID</button>
            </div>

            @if (drivers.Count > 0)
            {
                <table class="sga-table" style="margin-top:0.5rem;">
                    <thead>
                        <tr>
                            <th>Driver ID</th>
                            <th>Nombre</th>
                            <th>Licencia</th>
                            <th>Disponible</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var driver in drivers)
                        {
                            <tr>
                                <td>@driver.DriverId</td>
                                <td>@driver.FullName</td>
                                <td>@driver.DriverLicense</td>
                                <td>@(driver.IsAvailable ? "Si" : "No")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <label>Autobus</label>
            <select class="sga-input" @bind="createModel.BusId">
                <option value="0">Selecciona un autobus</option>
                @foreach (var bus in buses)
                {
                    <option value="@bus.Id">@bus.LicensePlate - @bus.Model (@bus.Capacity asientos)</option>
                }
            </select>

            <label>Fecha salida</label>
            <input @bind="createModel.DepartureDate" type="date" class="sga-input" />

            <label>Hora salida</label>
            <input @bind="createModel.DepartureHour" type="time" class="sga-input" />

            <label>Fecha llegada</label>
            <input @bind="createModel.ArrivalDate" type="date" class="sga-input" />

            <label>Hora llegada</label>
            <input @bind="createModel.ArrivalHour" type="time" class="sga-input" />

            <label>Asientos disponibles</label>
            <input @bind="createModel.AvailableSeats" type="number" class="sga-input" />

            <label>Creado por</label>
            <input @bind="createdBy" class="sga-input" />

            <button class="sga-btn" @onclick="CreateTripAsync">Registrar viaje</button>
        </div>
    </article>

    <div class="sga-inline-actions operator-actions">
        <input @bind="selectedTripId" type="number" class="sga-input" placeholder="Trip ID" />
        <input @bind="modifiedBy" class="sga-input" placeholder="Usuario operador" />
        <button class="sga-btn alt" @onclick="StartTripAsync">Iniciar</button>
        <button class="sga-btn alt" @onclick="CompleteTripAsync">Completar</button>
        <button class="sga-btn danger" @onclick="CancelTripAsync">Cancelar</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <p class="sga-alert">@message</p>
    }

