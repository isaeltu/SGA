@page "/portal/operador"
@rendermode InteractiveServer
@inject SGA.Web.Services.SgaApiClient ApiClient
@inject SGA.Web.Services.PortalSessionService Session
@inject NavigationManager Navigation

<section class="sga-section">
    <h1>Portal Operador</h1>
    <p class="lead">Gestiona buses, rutas y viajes para que los clientes reserven con informacion clara.</p>

    <div class="sga-form-grid">
        <label>Institucion asignada al operador</label>
        <input class="sga-input" value="@institutionLabel" readonly />
    </div>

    <article class="sga-card">
        <h3>Crear autobus</h3>
        <div class="sga-form-grid compact">
            <label>Placa</label>
            <input @bind="busModel.LicensePlate" class="sga-input" />

            <label>Modelo</label>
            <input @bind="busModel.Model" class="sga-input" />

            <label>Anio</label>
            <input @bind="busModel.Year" type="number" class="sga-input" />

            <label>Capacidad</label>
            <input @bind="busModel.Capacity" type="number" class="sga-input" />

            <button class="sga-btn alt" @onclick="CreateBusAsync">Registrar autobus</button>
        </div>
    </article>

    <article class="sga-card">
        <h3>Crear ruta</h3>
        <div class="sga-form-grid compact">
            <label>Nombre de ruta</label>
            <input @bind="routeModel.Name" class="sga-input" />

            <label>Origen</label>
            <input @bind="routeModel.Origin" class="sga-input" />

            <label>Destino</label>
            <input @bind="routeModel.Destination" class="sga-input" />

            <label>Distancia (km)</label>
            <input @bind="routeModel.DistanceKm" type="number" step="0.1" class="sga-input" />

            <label>Duracion estimada (min)</label>
            <input @bind="routeModel.EstimatedDurationMinutes" type="number" class="sga-input" />

            <button class="sga-btn alt" @onclick="CreateRouteAsync">Registrar ruta</button>
        </div>
    </article>

    <article class="sga-card">
        <h3>Crear viaje</h3>
        <div class="sga-form-grid compact">
            <label>Ruta</label>
            <select class="sga-input" @bind="createModel.RouteId">
                <option value="0">Selecciona una ruta</option>
                @foreach (var route in routes)
                {
                    <option value="@route.Id">@route.Name (@route.Origin -> @route.Destination)</option>
                }
            </select>

            <label>Driver ID</label>
            <input @bind="createModel.DriverId" type="number" class="sga-input" />

            <label>Drivers disponibles</label>
            <div class="sga-inline-actions operator-actions">
                <select class="sga-input" @bind="selectedDriverId">
                    <option value="0">Selecciona un driver</option>
                    @foreach (var driver in drivers)
                    {
                        <option value="@driver.DriverId">@driver.FullName - @driver.DriverLicense</option>
                    }
                </select>
                <button class="sga-btn alt" @onclick="LoadDriversAsync">Cargar drivers</button>
                <button class="sga-btn alt" @onclick="ApplySelectedDriver">Autocompletar Driver ID</button>
            </div>

            <label>Autobus</label>
            <select class="sga-input" @bind="createModel.BusId">
                <option value="0">Selecciona un autobus</option>
                @foreach (var bus in buses)
                {
                    <option value="@bus.Id">@bus.LicensePlate - @bus.Model (@bus.Capacity asientos)</option>
                }
            </select>

            <label>Fecha salida</label>
            <input @bind="createModel.DepartureDate" type="date" class="sga-input" />

            <label>Hora salida</label>
            <input @bind="createModel.DepartureHour" type="time" class="sga-input" />

            <label>Fecha llegada</label>
            <input @bind="createModel.ArrivalDate" type="date" class="sga-input" />

            <label>Hora llegada</label>
            <input @bind="createModel.ArrivalHour" type="time" class="sga-input" />

            <label>Asientos disponibles</label>
            <input @bind="createModel.AvailableSeats" type="number" class="sga-input" />

            <label>Creado por</label>
            <input @bind="createdBy" class="sga-input" />

            <button class="sga-btn" @onclick="CreateTripAsync">Registrar viaje</button>
        </div>
    </article>

    <div class="sga-inline-actions operator-actions">
        <input @bind="selectedTripId" type="number" class="sga-input" placeholder="Trip ID" />
        <input @bind="modifiedBy" class="sga-input" placeholder="Usuario operador" />
        <button class="sga-btn alt" @onclick="StartTripAsync">Iniciar</button>
        <button class="sga-btn alt" @onclick="CompleteTripAsync">Completar</button>
        <button class="sga-btn danger" @onclick="CancelTripAsync">Cancelar</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <p class="sga-alert">@message</p>
    }

    <div class="sga-grid-cards">
        @foreach (var trip in trips)
        {
            <article class="sga-card" @onclick="() => selectedTripId = trip.Id">
                <h3>Viaje @trip.Id</h3>
                <p>Ruta: @(string.IsNullOrWhiteSpace(trip.RouteName) ? $"ID {trip.RouteId}" : trip.RouteName) | Driver: @trip.DriverId | Bus: @trip.BusId</p>
                <p>Estado: @trip.Status</p>
                <p>Salida: @trip.ScheduledDepartureTime.ToLocalTime()</p>
                <p>Llegada: @trip.ScheduledArrivalTime.ToLocalTime()</p>
                <p>Disponibles: @trip.AvailableSeats</p>
            </article>
        }
    </div>
</section>

@code {
    private List<SGA.Web.Models.TripResponse> trips = new();
    private List<SGA.Web.Models.RouteResponse> routes = new();
    private List<SGA.Web.Models.BusResponse> buses = new();
    private List<SGA.Web.Models.DriverLookupResponse> drivers = new();
    private int selectedInstitutionId;
    private int selectedTripId;
    private int selectedDriverId;
    private string institutionLabel = "No asignada";
    private string createdBy = "web-operator";
    private string modifiedBy = "web-operator";
    private string? message;
    private bool redirectToLogin;

    private readonly TripCreateForm createModel = new();
    private readonly BusCreateForm busModel = new();
    private readonly RouteCreateForm routeModel = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Session.CanAccess(SGA.Web.Services.PortalRole.Operator))
        {
            redirectToLogin = true;
            return;
        }

        selectedInstitutionId = Session.InstitutionId;
        modifiedBy = string.IsNullOrWhiteSpace(Session.Email) ? modifiedBy : Session.Email;
        createdBy = string.IsNullOrWhiteSpace(Session.Email) ? createdBy : Session.Email;

        if (selectedInstitutionId <= 0)
        {
            message = "No se pudo determinar la institucion del operador. Contacta al administrador.";
            return;
        }

        var institution = await ApiClient.GetInstitutionByIdAsync(selectedInstitutionId, CancellationToken.None);
        institutionLabel = institution is null
            ? $"Institucion ID {selectedInstitutionId}"
            : $"{institution.Name} ({institution.Code})";

        await LoadRoutesAsync();
        await LoadBusesAsync();
        await LoadDriversAsync();
        await LoadTripsAsync();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && redirectToLogin)
        {
            Navigation.NavigateTo("/login-portal?portal=operador");
        }

        return Task.CompletedTask;
    }

    private async Task LoadTripsAsync()
    {
        var response = await ApiClient.GetTripsAsync(selectedInstitutionId, false, CancellationToken.None);
        trips = response?.ToList() ?? new List<SGA.Web.Models.TripResponse>();
    }

    private async Task LoadRoutesAsync()
    {
        var response = await ApiClient.GetRoutesAsync(selectedInstitutionId, CancellationToken.None);
        routes = response?.Where(x => x.IsActive).OrderBy(x => x.Name).ToList() ?? new List<SGA.Web.Models.RouteResponse>();
    }

    private async Task LoadBusesAsync()
    {
        var response = await ApiClient.GetBusesAsync(CancellationToken.None);
        buses = response?.Where(x => x.InstitutionId == selectedInstitutionId).ToList() ?? new List<SGA.Web.Models.BusResponse>();
    }

    private async Task LoadDriversAsync()
    {
        var response = await ApiClient.GetDriversAsync(selectedInstitutionId, true, CancellationToken.None);
        drivers = response?.OrderBy(x => x.FullName).ToList() ?? new List<SGA.Web.Models.DriverLookupResponse>();

        if (drivers.Count == 0)
        {
            message = "No hay drivers disponibles para esta institucion.";
        }
    }

    private void ApplySelectedDriver()
    {
        if (selectedDriverId <= 0)
        {
            message = "Selecciona un driver antes de autocompletar.";
            return;
        }

        createModel.DriverId = selectedDriverId;
        message = $"Driver ID autocompletado: {selectedDriverId}.";
    }

    private async Task CreateBusAsync()
    {
        message = null;
        if (string.IsNullOrWhiteSpace(busModel.LicensePlate) || string.IsNullOrWhiteSpace(busModel.Model) || busModel.Capacity <= 0)
        {
            message = "Completa placa, modelo y capacidad valida para registrar el autobus.";
            return;
        }

        try
        {
            var busId = await ApiClient.CreateBusAsync(
                new SGA.Web.Models.CreateBusRequest(
                    selectedInstitutionId,
                    busModel.LicensePlate.Trim(),
                    busModel.Model.Trim(),
                    busModel.Year,
                    busModel.Capacity,
                    createdBy),
                CancellationToken.None);

            message = $"Autobus registrado con ID {busId}.";
            await LoadBusesAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task CreateRouteAsync()
    {
        message = null;
        if (string.IsNullOrWhiteSpace(routeModel.Name) ||
            string.IsNullOrWhiteSpace(routeModel.Origin) ||
            string.IsNullOrWhiteSpace(routeModel.Destination) ||
            routeModel.DistanceKm <= 0 ||
            routeModel.EstimatedDurationMinutes <= 0)
        {
            message = "Completa nombre, origen, destino, distancia y duracion para registrar la ruta.";
            return;
        }

        try
        {
            var routeId = await ApiClient.CreateRouteAsync(
                new SGA.Web.Models.CreateRouteRequest(
                    selectedInstitutionId,
                    routeModel.Name.Trim(),
                    routeModel.Origin.Trim(),
                    routeModel.Destination.Trim(),
                    routeModel.DistanceKm,
                    routeModel.EstimatedDurationMinutes,
                    createdBy),
                CancellationToken.None);

            message = $"Ruta registrada con ID {routeId}.";
            await LoadRoutesAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task CreateTripAsync()
    {
        message = null;
        if (selectedInstitutionId <= 0)
        {
            message = "Selecciona una institucion para registrar el viaje.";
            return;
        }

        if (createModel.RouteId <= 0 || createModel.BusId <= 0 || createModel.DriverId <= 0)
        {
            message = "Selecciona ruta, autobus y driver validos para crear el viaje.";
            return;
        }

        try
        {
            var departure = createModel.DepartureDate.Date + createModel.DepartureHour.TimeOfDay;
            var arrival = createModel.ArrivalDate.Date + createModel.ArrivalHour.TimeOfDay;

            var id = await ApiClient.CreateTripAsync(
                new SGA.Web.Models.CreateTripRequest(
                    createModel.RouteId,
                    createModel.DriverId,
                    createModel.BusId,
                    selectedInstitutionId,
                    departure.ToUniversalTime(),
                    arrival.ToUniversalTime(),
                    createModel.AvailableSeats,
                    createdBy),
                CancellationToken.None);

            selectedTripId = id;
            message = $"Viaje registrado con ID {id}.";
            await LoadTripsAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task StartTripAsync() => await ExecuteTripActionAsync(
        () => ApiClient.StartTripAsync(new SGA.Web.Models.StartTripRequest(selectedTripId, modifiedBy), CancellationToken.None),
        "Viaje iniciado.");

    private async Task CompleteTripAsync() => await ExecuteTripActionAsync(
        () => ApiClient.CompleteTripAsync(new SGA.Web.Models.CompleteTripRequest(selectedTripId, modifiedBy), CancellationToken.None),
        "Viaje completado.");

    private async Task CancelTripAsync() => await ExecuteTripActionAsync(
        () => ApiClient.CancelTripAsync(new SGA.Web.Models.CancelTripRequest(selectedTripId, modifiedBy), CancellationToken.None),
        "Viaje cancelado.");

    private async Task ExecuteTripActionAsync(Func<Task> action, string successMessage)
    {
        message = null;
        if (selectedTripId <= 0)
        {
            message = "Selecciona un viaje valido.";
            return;
        }

        try
        {
            await action();
            message = successMessage;
            await LoadTripsAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private sealed class TripCreateForm
    {
        public int RouteId { get; set; }
        public int DriverId { get; set; }
        public int BusId { get; set; }
        public DateTime DepartureDate { get; set; } = DateTime.Today;
        public DateTime DepartureHour { get; set; } = DateTime.Today.AddHours(7);
        public DateTime ArrivalDate { get; set; } = DateTime.Today;
        public DateTime ArrivalHour { get; set; } = DateTime.Today.AddHours(8);
        public int? AvailableSeats { get; set; } = 40;
    }

    private sealed class BusCreateForm
    {
        public string LicensePlate { get; set; } = string.Empty;
        public string Model { get; set; } = string.Empty;
        public int Year { get; set; } = DateTime.Today.Year;
        public int Capacity { get; set; } = 40;
    }

    private sealed class RouteCreateForm
    {
        public string Name { get; set; } = string.Empty;
        public string Origin { get; set; } = string.Empty;
        public string Destination { get; set; } = string.Empty;
        public decimal DistanceKm { get; set; } = 1;
        public int EstimatedDurationMinutes { get; set; } = 20;
    }
}