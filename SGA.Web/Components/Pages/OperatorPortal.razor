@page "/portal/operador"
@rendermode InteractiveServer
@inject SGA.Web.Services.SgaApiClient ApiClient
@inject SGA.Web.Services.PortalSessionService Session
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject SGA.Web.Services.UiFeedbackService Ui

<section class="sga-section">
    <div>
        <h1>Portal Operador</h1>
        <p class="lead">Gestiona buses, rutas y viajes para que los clientes reserven con informacion clara.</p>
    </div>

    <div class="sga-metrics-grid">
        <article class="sga-metric-card">
            <div class="sga-metric-icon">
                <img src="icons/transport/bus.svg" alt="Buses" />
            </div>
            <div>
                <span class="sga-metric-label">Buses</span>
                <div class="sga-metric-value">@buses.Count</div>
                <p class="sga-metric-copy">Unidades activas en la institucion actual.</p>
            </div>
            <div class="sga-metric-actions">
                <a class="sga-btn alt" href="#section-buses">
                    <img src="icons/nav/plus.svg" alt="" />
                    Registrar
                </a>
            </div>
        </article>

        <article class="sga-metric-card">
            <div class="sga-metric-icon">
                <img src="icons/nav/map-pin.svg" alt="Rutas" />
            </div>
            <div>
                <span class="sga-metric-label">Rutas</span>
                <div class="sga-metric-value">@routes.Count</div>
                <p class="sga-metric-copy">Trayectos disponibles para programar viajes.</p>
            </div>
            <div class="sga-metric-actions">
                <a class="sga-btn alt" href="#section-routes">
                    <img src="icons/nav/eye.svg" alt="" />
                    Revisar
                </a>
            </div>
        </article>

        <article class="sga-metric-card">
            <div class="sga-metric-icon">
                <img src="icons/nav/navigation.svg" alt="Viajes" />
            </div>
            <div>
                <span class="sga-metric-label">Viajes</span>
                <div class="sga-metric-value">@trips.Count</div>
                <p class="sga-metric-copy">Servicios cargados para la operación diaria.</p>
            </div>
            <div class="sga-metric-actions">
                <a class="sga-btn alt" href="#section-trips">
                    <img src="icons/nav/eye.svg" alt="" />
                    Ver viajes
                </a>
            </div>
        </article>

        <article class="sga-metric-card">
            <div class="sga-metric-icon">
                <img src="icons/nav/user.svg" alt="Drivers" />
            </div>
            <div>
                <span class="sga-metric-label">Drivers</span>
                <div class="sga-metric-value">@drivers.Count</div>
                <p class="sga-metric-copy">Conductores disponibles para asignacion.</p>
            </div>
            <div class="sga-metric-actions">
                <a class="sga-btn alt" href="#section-trips">
                    <img src="icons/nav/plus.svg" alt="" />
                    Asignar
                </a>
            </div>
        </article>
    </div>

    <article class="sga-card" id="section-contexto">
        <div class="sga-card-header">
            <div>
                <h3>Contexto de trabajo</h3>
                <p class="sga-panel-note">Selecciona la institucion para cargar buses, rutas, drivers y viajes.</p>
            </div>
            <div class="sga-row-actions">
                <button type="button" class="sga-icon-btn alt" @onclick="LoadInstitutionContextAsync" title="Recargar contexto">
                    <img src="icons/nav/eye.svg" alt="" />
                </button>
            </div>
        </div>

        <div class="sga-form-full single-col">
            <div class="sga-field">
                <label>Institucion de trabajo</label>
                @if (Session.InstitutionId > 0)
                {
                    <input class="sga-input" value="@institutionLabel" readonly />
                }
                else
                {
                    <select class="sga-input" @bind="selectedInstitutionId" @bind:after="OnInstitutionChangedAsync">
                        <option value="0">Selecciona una institucion</option>
                        @foreach (var institution in institutions)
                        {
                            <option value="@institution.Id">@institution.Name (@institution.Code)</option>
                        }
                    </select>
                }
            </div>
        </div>
    </article>

    <div class="sga-two-col">
        <article class="sga-card" id="section-buses">
            <div class="sga-card-header">
                <div>
                    <h3>Autobuses</h3>
                    <p class="sga-panel-note">Alta, consulta y baja de la flota asignada a la institucion.</p>
                </div>
                <div class="sga-row-actions">
                    <button type="button" class="sga-icon-btn alt" @onclick="LoadBusesAsync" title="Refrescar buses">
                        <img src="icons/nav/eye.svg" alt="" />
                    </button>
                </div>
            </div>

            <div class="sga-form-full">
                <div class="sga-field">
                    <label>Placa</label>
                    <input @bind="busModel.LicensePlate" class="sga-input" />
                </div>

                <div class="sga-field">
                    <label>Modelo</label>
                    <input @bind="busModel.Model" class="sga-input" />
                </div>

                <div class="sga-field">
                    <label>Anio</label>
                    <input @bind="busModel.Year" type="number" class="sga-input" />
                </div>

                <div class="sga-field">
                    <label>Capacidad</label>
                    <input @bind="busModel.Capacity" type="number" class="sga-input" />
                </div>

                <button class="sga-btn alt" style="grid-column: 1 / -1;" @onclick="CreateBusAsync">Registrar autobus</button>
            </div>

            @if (buses.Count > 0)
            {
                <table class="sga-table" style="margin-top:1rem;">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Placa</th>
                            <th>Modelo</th>
                            <th>Capacidad</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bus in buses)
                        {
                            <tr>
                                <td>@bus.Id</td>
                                <td>@bus.LicensePlate</td>
                                <td>@bus.Model</td>
                                <td>@bus.Capacity</td>
                                <td>@bus.Status</td>
                                <td>
                                    <div class="sga-row-actions">
                                        <button type="button" class="sga-icon-btn alt" @onclick="() => SelectBus(bus)" title="Seleccionar bus">
                                            <img src="icons/nav/eye.svg" alt="" />
                                        </button>
                                        <button type="button" class="sga-icon-btn danger" @onclick="() => DeleteBusAsync(bus.Id)" title="Eliminar bus">
                                            <img src="icons/nav/trash.svg" alt="" />
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="sga-empty">No hay buses registrados para esta institucion.</div>
            }
        </article>

        <article class="sga-card" id="section-routes">
            <div class="sga-card-header">
                <div>
                    <h3>Rutas</h3>
                    <p class="sga-panel-note">Configura trayectos, edita datos y activa o elimina rutas.</p>
                </div>
                <div class="sga-row-actions">
                    <button type="button" class="sga-icon-btn alt" @onclick="LoadRoutesAsync" title="Refrescar rutas">
                        <img src="icons/nav/eye.svg" alt="" />
                    </button>
                </div>
            </div>

            <div class="sga-form-full">
                <div class="sga-field">
                    <label>Nombre de ruta</label>
                    <input @bind="routeModel.Name" class="sga-input" />
                </div>

                <div class="sga-field">
                    <label>Origen</label>
                    <input @bind="routeModel.Origin" class="sga-input" />
                </div>

                <div class="sga-field">
                    <label>Destino</label>
                    <input @bind="routeModel.Destination" class="sga-input" />
                </div>

                <div class="sga-field">
                    <label>Distancia (km)</label>
                    <input @bind="routeModel.DistanceKm" type="number" step="0.1" class="sga-input" />
                </div>

                <div class="sga-field">
                    <label>Duracion estimada (min)</label>
                    <input @bind="routeModel.EstimatedDurationMinutes" type="number" class="sga-input" />
                </div>

                <button class="sga-btn alt" style="grid-column: 1 / -1;" @onclick="CreateRouteAsync">Registrar ruta</button>
            </div>

            <div class="sga-form-full" style="margin-top:1rem;">
                <div class="sga-field" style="grid-column: 1 / -1;">
                    <label>Ruta seleccionada para editar</label>
                    <select class="sga-input" @bind="selectedRouteId" @bind:after="LoadSelectedRouteForEditAsync">
                        <option value="0">Selecciona una ruta</option>
                        @foreach (var route in routes)
                        {
                            <option value="@route.Id">@route.Name (@route.Origin -> @route.Destination)</option>
                        }
                    </select>
                </div>

                @if (selectedRouteId > 0)
                {
                    <div class="sga-field">
                        <label>Nombre (edicion)</label>
                        <input @bind="routeEditModel.Name" class="sga-input" />
                    </div>

                    <div class="sga-field">
                        <label>Origen (edicion)</label>
                        <input @bind="routeEditModel.Origin" class="sga-input" />
                    </div>

                    <div class="sga-field">
                        <label>Destino (edicion)</label>
                        <input @bind="routeEditModel.Destination" class="sga-input" />
                    </div>

                    <div class="sga-field">
                        <label>Distancia (km)</label>
                        <input @bind="routeEditModel.DistanceKm" type="number" step="0.1" class="sga-input" />
                    </div>

                    <div class="sga-field">
                        <label>Duracion estimada (min)</label>
                        <input @bind="routeEditModel.EstimatedDurationMinutes" type="number" class="sga-input" />
                    </div>

                    <div class="sga-field">
                        <label>Activa</label>
                        <input @bind="routeEditModel.IsActive" type="checkbox" class="sga-input" />
                    </div>

                    <button class="sga-btn alt" style="grid-column: 1 / -1;" @onclick="UpdateRouteAsync">Actualizar ruta</button>
                    <button class="sga-btn danger" style="grid-column: 1 / -1;" @onclick="DeleteSelectedRouteAsync">Eliminar ruta</button>
                }
            </div>

            <div class="sga-inline-actions operator-actions" style="margin-top:1rem;">
                <button class="sga-btn alt" @onclick="LoadRoutesAsync">Recargar rutas</button>
                <span>Total rutas: @routes.Count</span>
            </div>

            @if (routes.Count > 0)
            {
                <table class="sga-table" style="margin-top:1rem;">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Origen</th>
                            <th>Destino</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var route in routes)
                        {
                            <tr>
                                <td>@route.Id</td>
                                <td>@route.Name</td>
                                <td>@route.Origin</td>
                                <td>@route.Destination</td>
                                <td>@(route.IsActive ? "Activa" : "Inactiva")</td>
                                <td>
                                    <div class="sga-row-actions">
                                        <button type="button" class="sga-icon-btn alt" @onclick="() => SelectRoute(route.Id)" title="Editar ruta">
                                            <img src="icons/nav/pencil.svg" alt="" />
                                        </button>
                                        <button type="button" class="sga-icon-btn danger" @onclick="() => DeleteRouteByIdAsync(route.Id)" title="Eliminar ruta">
                                            <img src="icons/nav/trash.svg" alt="" />
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="sga-empty">No hay rutas disponibles. Crea una ruta para habilitar viajes.</div>
            }
        </article>
    </div>

    <article/> class="sga-card" id="section-trips"
        <div class="sga-card-header">
            <div>
                <h3>Viajes</h3>
                <p class="sga-panel-note">Programa salidas, inicia, completa o cancela desde un mismo panel.</p>
            </div>
            <div class="sga-row-actions">
                <button type="button" class="sga-icon-btn alt" @onclick="LoadTripsAsync" title="Refrescar viajes">
                    <img src="icons/nav/eye.svg" alt="" />
                </button>
            </div>
        </div>

        <div class="sga-form-full">
            <div class="sga-field">
                <label>Ruta</label>
                <select class="sga-input" @bind="createModel.RouteId">
                    <option value="0">Selecciona una ruta</option>
                    @foreach (var route in routes)
                    {
                        <option value="@route.Id">@route.Name (@route.Origin -> @route.Destination)</option>
                    }
                </select>
            </div>

            <div class="sga-field">
                <label>Driver ID</label>
                <input @bind="createModel.DriverId" type="number" class="sga-input" />
            </div>

            <div class="sga-field" style="grid-column: 1 / -1;">
                <label>Drivers disponibles</label>
                <div class="sga-inline-actions operator-actions">
                    <select class="sga-input" @bind="selectedDriverId">
                        <option value="0">Selecciona un driver</option>
                        @foreach (var driver in drivers)
                        {
                            <option value="@driver.DriverId">@driver.FullName - @driver.DriverLicense</option>
                        }
                    </select>
                    <button class="sga-btn alt" @onclick="LoadDriversAsync">Cargar drivers</button>
                    <button class="sga-btn alt" @onclick="ApplySelectedDriver">Autocompletar Driver ID</button>
                </div>
            </div>

            @if (drivers.Count > 0)
            {
                <div style="grid-column: 1 / -1;">
                    <table class="sga-table" style="margin-top:0.5rem;">
                        <thead>
                            <tr>
                                <th>Driver ID</th>
                                <th>Nombre</th>
                                <th>Licencia</th>
                                <th>Disponible</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var driver in drivers)
                            {
                                <tr>
                                    <td>@driver.DriverId</td>
                                    <td>@driver.FullName</td>
                                    <td>@driver.DriverLicense</td>
                                    <td>@(driver.IsAvailable ? "Si" : "No")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="sga-field">
                <label>Autobus</label>
                <select class="sga-input" @bind="createModel.BusId">
                    <option value="0">Selecciona un autobus</option>
                    @foreach (var bus in buses)
                    {
                        <option value="@bus.Id">@bus.LicensePlate - @bus.Model (@bus.Capacity asientos)</option>
                    }
                </select>
            </div>

            <div class="sga-field">
                <label>Fecha salida</label>
                <input @bind="createModel.DepartureDate" type="date" class="sga-input" />
            </div>

            <div class="sga-field">
                <label>Hora salida</label>
                <input @bind="createModel.DepartureHour" type="time" class="sga-input" />
            </div>

            <div class="sga-field">
                <label>Fecha llegada</label>
                <input @bind="createModel.ArrivalDate" type="date" class="sga-input" />
            </div>

            <div class="sga-field">
                <label>Hora llegada</label>
                <input @bind="createModel.ArrivalHour" type="time" class="sga-input" />
            </div>

            <div class="sga-field">
                <label>Asientos disponibles</label>
                <input @bind="createModel.AvailableSeats" type="number" class="sga-input" />
            </div>

            <div class="sga-field">
                <label>Creado por</label>
                <input @bind="createdBy" class="sga-input" />
            </div>

            <button class="sga-btn" style="grid-column: 1 / -1;" @onclick="CreateTripAsync">Registrar viaje</button>

    <div class="sga-inline-actions operator-actions">
        <input @bind="selectedTripId" type="number" class="sga-input" placeholder="Trip ID" />
        <input @bind="modifiedBy" class="sga-input" placeholder="Usuario operador" />
        <button class="sga-btn alt" @onclick="StartTripAsync">Iniciar</button>
        <button class="sga-btn alt" @onclick="CompleteTripAsync">Completar</button>
        <button class="sga-btn danger" @onclick="CancelTripAsync">Cancelar</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <p class="sga-alert">@message</p>
    }

    @if (trips.Count > 0)
    {
        <div class="sga-grid-cards">
            @foreach (var trip in trips)
            {
                <article class="sga-card" @onclick="() => selectedTripId = trip.Id">
                    <h3>@(string.IsNullOrWhiteSpace(trip.RouteName) ? $"Ruta ID {trip.RouteId}" : trip.RouteName)</h3>
                    <p>Ruta: @(string.IsNullOrWhiteSpace(trip.RouteName) ? $"ID {trip.RouteId}" : trip.RouteName) | Driver: @trip.DriverId | Bus: @trip.BusId</p>
                    <p>Estado: @trip.Status</p>
                    <p>Salida: @trip.ScheduledDepartureTime.ToLocalTime()</p>
                    <p>Llegada: @trip.ScheduledArrivalTime.ToLocalTime()</p>
                    <p>Disponibles: @trip.AvailableSeats</p>
                </article>
            }
        </div>
    }
    else
    {
        <div class="sga-empty">Aun no hay viajes cargados para esta institucion.</div>
    }
</section>

@code {
    private List<SGA.Web.Models.InstitutionResponse> institutions = new();
    private List<SGA.Web.Models.TripResponse> trips = new();
    private List<SGA.Web.Models.RouteResponse> routes = new();
    private List<SGA.Web.Models.BusResponse> buses = new();
    private List<SGA.Web.Models.DriverLookupResponse> drivers = new();
    private int selectedInstitutionId;
    private int selectedTripId;
    private int selectedDriverId;
    private int selectedRouteId;
    private string institutionLabel = "No asignada";
    private string createdBy = "web-operator";
    private string modifiedBy = "web-operator";
    private string? message;
    private bool redirectToLogin;

    private readonly TripCreateForm createModel = new();
    private readonly BusCreateForm busModel = new();
    private readonly RouteCreateForm routeModel = new();
    private readonly RouteEditForm routeEditModel = new();

    protected override async Task OnInitializedAsync()
    {
        using var busy = Ui.BeginBusy();
        if (!Session.CanAccess(SGA.Web.Services.PortalRole.Operator))
        {
            redirectToLogin = true;
            return;
        }

        try
        {
            var institutionResponse = await ApiClient.GetInstitutionsAsync(CancellationToken.None);
            institutions = institutionResponse?.Where(i => i.IsActive).OrderBy(i => i.Name).ToList()
                ?? new List<SGA.Web.Models.InstitutionResponse>();
        }
        catch (Exception ex)
        {
            message = $"No se pudo cargar instituciones: {ex.Message}";
            institutions = new List<SGA.Web.Models.InstitutionResponse>();
            return;
        }

        selectedInstitutionId = Session.InstitutionId;
        modifiedBy = string.IsNullOrWhiteSpace(Session.Email) ? modifiedBy : Session.Email;
        createdBy = string.IsNullOrWhiteSpace(Session.Email) ? createdBy : Session.Email;

        if (selectedInstitutionId <= 0)
        {
            message = "Tu cuenta no tiene institucion asignada. Selecciona una institucion para continuar.";
            return;
        }

        await LoadInstitutionContextAsync();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && redirectToLogin)
        {
            Navigation.NavigateTo("/login-portal?portal=operador");
        }

        return Task.CompletedTask;
    }

    private async Task LoadTripsAsync()
    {
        using var busy = Ui.BeginBusy();
        if (selectedInstitutionId <= 0)
        {
            trips.Clear();
            return;
        }

        try
        {
            var response = await ApiClient.GetTripsAsync(selectedInstitutionId, false, CancellationToken.None);
            trips = response?.ToList() ?? new List<SGA.Web.Models.TripResponse>();
        }
        catch (Exception ex)
        {
            trips.Clear();
            message = $"No se pudieron cargar viajes: {ex.Message}";
            Ui.ShowError("No se pudieron cargar los viajes", ex.Message);
        }
    }

    private async Task LoadRoutesAsync()
    {
        using var busy = Ui.BeginBusy();
        if (selectedInstitutionId <= 0)
        {
            routes.Clear();
            return;
        }

        try
        {
            var response = await ApiClient.GetRoutesAsync(selectedInstitutionId, CancellationToken.None);
            routes = response?.Where(x => x.IsActive).OrderBy(x => x.Name).ToList() ?? new List<SGA.Web.Models.RouteResponse>();
            if (routes.Count > 0)
            {
                message = $"Se cargaron {routes.Count} rutas.";
                Ui.ShowSuccess("Rutas cargadas", message);
            }
            else
            {
                Ui.ShowInfo("Sin rutas", "No hay rutas activas para esta institucion.");
            }
        }
        catch (Exception ex)
        {
            routes.Clear();
            message = $"No se pudieron cargar rutas: {ex.Message}";
            Ui.ShowError("No se pudieron cargar las rutas", ex.Message);
        }
    }

    private async Task LoadBusesAsync()
    {
        using var busy = Ui.BeginBusy();
        if (selectedInstitutionId <= 0)
        {
            buses.Clear();
            return;
        }

        try
        {
            var response = await ApiClient.GetBusesAsync(CancellationToken.None);
            buses = response?.Where(x => x.InstitutionId == selectedInstitutionId).ToList() ?? new List<SGA.Web.Models.BusResponse>();
        }
        catch (Exception ex)
        {
            buses.Clear();
            message = $"No se pudieron cargar autobuses: {ex.Message}";
            Ui.ShowError("No se pudieron cargar los buses", ex.Message);
        }
    }

    private async Task LoadDriversAsync()
    {
        using var busy = Ui.BeginBusy();
        if (selectedInstitutionId <= 0)
        {
            drivers.Clear();
            return;
        }

        try
        {
            var response = await ApiClient.GetDriversAsync(selectedInstitutionId, false, CancellationToken.None);
            drivers = response?.OrderBy(x => x.FullName).ToList() ?? new List<SGA.Web.Models.DriverLookupResponse>();

            if (drivers.Count == 0)
            {
                message = "No hay drivers disponibles para esta institucion.";
                Ui.ShowInfo("Sin drivers", message);
            }
            else
            {
                message = $"Se cargaron {drivers.Count} drivers.";
                Ui.ShowSuccess("Drivers cargados", message);
            }
        }
        catch (Exception ex)
        {
            drivers.Clear();
            message = $"No se pudieron cargar drivers: {ex.Message}";
            Ui.ShowError("No se pudieron cargar los drivers", ex.Message);
        }
    }

    private void ApplySelectedDriver()
    {
        if (selectedDriverId <= 0)
        {
            message = "Selecciona un driver antes de autocompletar.";
            return;
        }

        createModel.DriverId = selectedDriverId;
        message = $"Driver ID autocompletado: {selectedDriverId}.";
        Ui.ShowSuccess("Driver asignado", message);
    }

    private async Task CreateBusAsync()
    {
        using var busy = Ui.BeginBusy();
        message = null;
        if (string.IsNullOrWhiteSpace(busModel.LicensePlate) || string.IsNullOrWhiteSpace(busModel.Model) || busModel.Capacity <= 0)
        {
            message = "Completa placa, modelo y capacidad valida para registrar el autobus.";
            return;
        }

        var normalizedPlate = NormalizeLicensePlate(busModel.LicensePlate);
        if (!IsValidLicensePlate(normalizedPlate))
        {
            message = "La placa debe tener formato A123456.";
            return;
        }

        try
        {
            var busId = await ApiClient.CreateBusAsync(
                new SGA.Web.Models.CreateBusRequest(
                    selectedInstitutionId,
                    normalizedPlate,
                    busModel.Model.Trim(),
                    busModel.Year,
                    busModel.Capacity,
                    createdBy),
                CancellationToken.None);

            message = $"Autobus registrado con ID {busId}.";
            Ui.ShowSuccess("Bus registrado", message);
            await LoadBusesAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
            Ui.ShowError("No se pudo registrar el autobus", ex.Message);
        }
    }

    private async Task DeleteBusAsync(int busId)
    {
        using var busy = Ui.BeginBusy();
        message = null;
        try
        {
            if (!await ConfirmActionAsync($"Eliminar el autobus {busId}?"))
            {
                return;
            }

            await ApiClient.DeleteBusAsync(busId, CancellationToken.None);
            message = $"Autobus {busId} eliminado correctamente.";
            Ui.ShowWarning("Bus eliminado", message);
            await LoadBusesAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
            Ui.ShowError("No se pudo eliminar el autobus", ex.Message);
        }
    }

    private async Task CreateRouteAsync()
    {
        using var busy = Ui.BeginBusy();
        message = null;
        if (string.IsNullOrWhiteSpace(routeModel.Name) ||
            string.IsNullOrWhiteSpace(routeModel.Origin) ||
            string.IsNullOrWhiteSpace(routeModel.Destination) ||
            routeModel.DistanceKm <= 0 ||
            routeModel.EstimatedDurationMinutes <= 0)
        {
            message = "Completa nombre, origen, destino, distancia y duracion para registrar la ruta.";
            return;
        }

        try
        {
            var routeId = await ApiClient.CreateRouteAsync(
                new SGA.Web.Models.CreateRouteRequest(
                    selectedInstitutionId,
                    routeModel.Name.Trim(),
                    routeModel.Origin.Trim(),
                    routeModel.Destination.Trim(),
                    routeModel.DistanceKm,
                    routeModel.EstimatedDurationMinutes,
                    createdBy),
                CancellationToken.None);

            message = $"Ruta registrada con ID {routeId}.";
            Ui.ShowSuccess("Ruta registrada", message);
            await LoadRoutesAsync();
            selectedRouteId = routeId;
            await LoadSelectedRouteForEditAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
            Ui.ShowError("No se pudo registrar la ruta", ex.Message);
        }
    }

    private async Task LoadSelectedRouteForEditAsync()
    {
        using var busy = Ui.BeginBusy();
        if (selectedRouteId <= 0)
        {
            return;
        }

        try
        {
            var route = await ApiClient.GetRouteByIdAsync(selectedRouteId, CancellationToken.None);
            if (route is null)
            {
                message = "No se pudo cargar la ruta seleccionada.";
                Ui.ShowWarning("Ruta no encontrada", message);
                return;
            }

            routeEditModel.Name = route.Name;
            routeEditModel.Origin = route.Origin;
            routeEditModel.Destination = route.Destination;
            routeEditModel.DistanceKm = route.DistanceKm;
            routeEditModel.EstimatedDurationMinutes = route.EstimatedDurationMinutes;
            routeEditModel.IsActive = route.IsActive;
        }
        catch (Exception ex)
        {
            message = $"No se pudo cargar la ruta para editar: {ex.Message}";
            Ui.ShowError("No se pudo cargar la ruta", ex.Message);
        }
    }

    private async Task UpdateRouteAsync()
    {
        using var busy = Ui.BeginBusy();
        if (selectedRouteId <= 0)
        {
            message = "Selecciona una ruta para actualizar.";
            return;
        }

        try
        {
            await ApiClient.UpdateRouteAsync(
                new SGA.Web.Models.UpdateRouteRequest(
                    selectedRouteId,
                    selectedInstitutionId,
                    routeEditModel.Name.Trim(),
                    routeEditModel.Origin.Trim(),
                    routeEditModel.Destination.Trim(),
                    routeEditModel.DistanceKm,
