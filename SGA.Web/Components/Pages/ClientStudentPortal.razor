@page "/portal/cliente-estudiante"
@rendermode InteractiveServer
@inject SGA.Web.Services.SgaApiClient ApiClient
@inject IJSRuntime JS
@inject SGA.Web.Services.UiFeedbackService Ui

<section class="sga-section">
    <div>
        <h1>Portal Cliente y Estudiante</h1>
        <p class="lead">Reserva sin iniciar sesion: selecciona institucion y viaje. Tus datos son opcionales.</p>
    </div>

    <div class="sga-metrics-grid">
        <article class="sga-metric-card">
            <div class="sga-metric-icon">
                <img src="icons/nav/building.svg" alt="Instituciones" />
            </div>
            <div>
                <span class="sga-metric-label">Instituciones</span>
                <div class="sga-metric-value">@institutions.Count</div>
                <p class="sga-metric-copy">Instituciones con viajes disponibles para reservar.</p>
            </div>
            <div class="sga-metric-actions">
                <a class="sga-btn alt" href="#section-context">
                    <img src="icons/nav/pencil.svg" alt="" />
                    Elegir
                </a>
            </div>
        </article>

        <article class="sga-metric-card">
            <div class="sga-metric-icon">
                <img src="icons/nav/navigation.svg" alt="Viajes" />
            </div>
            <div>
                <span class="sga-metric-label">Viajes</span>
                <div class="sga-metric-value">@availableTrips.Count</div>
                <p class="sga-metric-copy">Opciones activas para la institucion seleccionada.</p>
            </div>
            <div class="sga-metric-actions">
                <a class="sga-btn alt" href="#section-trips">
                    <img src="icons/nav/eye.svg" alt="" />
                    Ver viajes
                </a>
            </div>
        </article>

        <article class="sga-metric-card">
            <div class="sga-metric-icon">
                <img src="icons/nav/user.svg" alt="Seleccion" />
            </div>
            <div>
                <span class="sga-metric-label">Trip seleccionado</span>
                <div class="sga-metric-value">@(selectedTripId > 0 ? selectedTripId : 0)</div>
                <p class="sga-metric-copy">Trip objetivo para generar reserva y ticket QR.</p>
            </div>
            <div class="sga-metric-actions">
                <a class="sga-btn alt" href="#section-booking">
                    <img src="icons/nav/plus.svg" alt="" />
                    Reservar
                </a>
            </div>
        </article>
    </div>

    <article class="sga-card" id="section-context">
        <div class="sga-card-header">
            <div>
                <h3>Contexto de reserva</h3>
                <p class="sga-panel-note">Selecciona una institucion para cargar los viajes disponibles.</p>
            </div>
        </div>

        <div class="sga-form-grid compact">
            <label>Institucion</label>
            <select class="sga-input" @bind="selectedInstitutionId" @bind:after="LoadAvailableTripsAsync">
                <option value="0">Selecciona una institucion</option>
                @foreach (var institution in institutions)
                {
                    <option value="@institution.Id">@institution.Name (@institution.Code)</option>
                }
            </select>
        </div>
    </article>

    <article class="sga-card" id="section-trips">
        <div class="sga-card-header">
            <div>
                <h3>Viajes disponibles</h3>
                <p class="sga-panel-note">Haz click en una tarjeta para seleccionar el viaje.</p>
            </div>
        </div>

        @if (availableTrips.Count > 0)
        {
            <div class="sga-grid-cards">
                @foreach (var trip in availableTrips)
                {
                    <article class="sga-card sga-trip-card @(selectedTripId == trip.Id ? "selected-card" : string.Empty)" @onclick="() => SelectTrip(trip.Id)">
                        <div class="sga-card-header">
                            <div>
                                <h3>@(string.IsNullOrWhiteSpace(trip.RouteName) ? $"Ruta ID {trip.RouteId}" : trip.RouteName)</h3>
                                <p class="sga-panel-note">Viaje #@trip.Id | Bus @trip.BusId</p>
                            </div>
                            <span class="sga-status-pill">@trip.Status</span>
                        </div>

                        <p>Ruta: @(string.IsNullOrWhiteSpace(trip.RouteName) ? $"ID {trip.RouteId}" : trip.RouteName)</p>
                        <p>Salida: @trip.ScheduledDepartureTime.ToLocalTime()</p>
                        <p>Llegada: @trip.ScheduledArrivalTime.ToLocalTime()</p>
                        <p>Disponibles: @trip.AvailableSeats</p>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="sga-empty">No hay viajes disponibles para la institucion seleccionada.</div>
        }
    </article>

    <article class="sga-card" id="section-booking">
        <div class="sga-card-header">
            <div>
                <h3>Datos para reserva</h3>
                <p class="sga-panel-note">Puedes reservar como invitado. Los campos personales son opcionales.</p>
            </div>
        </div>

        <div class="sga-two-col">
            <div class="sga-field">
                <label>Nombre (opcional)</label>
                <input @bind="guest.FirstName" class="sga-input" />
            </div>

            <div class="sga-field">
                <label>Apellido (opcional)</label>
                <input @bind="guest.LastName" class="sga-input" />
            </div>

            <div class="sga-field">
                <label>Correo (opcional)</label>
                <input @bind="guest.Email" type="email" class="sga-input" />
            </div>

            <div class="sga-field">
                <label>Telefono (opcional)</label>
                <input @bind="guest.PhoneNumber" placeholder="8091234567" class="sga-input" />
            </div>

            <button class="sga-btn" style="align-self: flex-end;" @onclick="CreateGuestReservationAsync">Reservar ahora</button>
        </div>
    </article>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <p class="sga-alert">@message</p>
    }

    @if (reservation is not null)
    {
        <article class="sga-ticket">
            <p class="title">Reserva confirmada</p>
            <p>Reserva: @reservation.Id</p>
            <p>Viaje: @reservation.TripId</p>
            @if (reservationTrip is not null)
            {
                <p>Ruta: @GetRouteLabel(reservationTrip)</p>
                <p>Salida: @FormatLocalDateTime(reservationTrip.ScheduledDepartureTime)</p>
                <p>Llegada: @FormatLocalDateTime(reservationTrip.ScheduledArrivalTime)</p>
            }
            <p>QR: @reservation.QrCode</p>
            <p>Estado: @reservation.Status</p>
            <p>Turno: @reservation.QueueNumber</p>

            <div class="sga-ticket-qr">
                @if (!string.IsNullOrWhiteSpace(ticketQrBase64))
                {
                    <img alt="QR de reserva" src="@($"data:image/png;base64,{ticketQrBase64}")" />
                }
                <div class="hero-actions">
                    <button type="button" class="sga-btn" @onclick="DownloadReservationTicketAsync">Descargar ticket</button>
                    <button type="button" class="sga-btn alt" @onclick="DownloadReservationQrAsync">Descargar QR</button>
                </div>
            </div>
        </article>
    }
</section>

@code {
    private List<SGA.Web.Models.InstitutionResponse> institutions = new();
    private List<SGA.Web.Models.TripResponse> availableTrips = new();
    private int selectedInstitutionId;
    private int lastLoadedInstitutionId;
    private int selectedTripId;
    private string? message;
    private SGA.Web.Models.ReservationResponse? reservation;
    private SGA.Web.Models.TripResponse? reservationTrip;
    private string? ticketQrBase64;

    private readonly GuestReservationForm guest = new();

    protected override async Task OnInitializedAsync()
    {
        using var busy = Ui.BeginBusy();
        try
        {
            var response = await ApiClient.GetInstitutionsAsync(CancellationToken.None);
            institutions = response?.Where(i => i.IsActive).ToList() ?? new List<SGA.Web.Models.InstitutionResponse>();
        }
        catch (Exception ex)
        {
            message = ex.Message;
            Ui.ShowError("No se pudieron cargar instituciones", ex.Message);
        }
    }

    private async Task LoadAvailableTripsAsync()
    {
        using var busy = Ui.BeginBusy();

        var institutionChanged = selectedInstitutionId != lastLoadedInstitutionId;
        if (institutionChanged)
        {
            reservation = null;
            reservationTrip = null;
            ticketQrBase64 = null;
            selectedTripId = 0;
            lastLoadedInstitutionId = selectedInstitutionId;
        }

        if (selectedInstitutionId <= 0)
        {
            availableTrips.Clear();
            reservation = null;
            reservationTrip = null;
            ticketQrBase64 = null;
            return;
        }

        try
        {
            var response = await ApiClient.GetTripsAsync(selectedInstitutionId, true, CancellationToken.None);
            availableTrips = response?.ToList() ?? new List<SGA.Web.Models.TripResponse>();
            message = availableTrips.Count == 0
                ? "No hay viajes disponibles para esta institucion en este momento."
                : null;

            if (availableTrips.Count == 0)
            {
                Ui.ShowInfo("Sin viajes", message ?? "No hay viajes disponibles.");
            }
        }
        catch (Exception ex)
        {
            availableTrips.Clear();
            message = ex.Message;
            Ui.ShowError("No se pudieron cargar viajes", ex.Message);
        }
    }

    private void SelectTrip(int tripId)
    {
        selectedTripId = tripId;
        message = null;
        Ui.ShowInfo("Viaje seleccionado", $"Trip {tripId} listo para reservar.");
    }

    private async Task CreateGuestReservationAsync()
    {
        using var busy = Ui.BeginBusy();
        message = null;
        reservation = null;
        reservationTrip = null;

        if (selectedInstitutionId <= 0)
        {
            message = "Selecciona una institucion.";
            Ui.ShowWarning("Datos incompletos", message);
            return;
        }

        if (selectedTripId <= 0)
        {
            message = "Selecciona un viaje disponible.";
            Ui.ShowWarning("Datos incompletos", message);
            return;
        }

        try
        {
            var reservationId = await ApiClient.CreateGuestReservationAsync(
                new SGA.Web.Models.CreateGuestReservationRequest(
                    selectedInstitutionId,
                    selectedTripId,
                    NormalizeOrNull(guest.FirstName),
                    NormalizeOrNull(guest.LastName),
                    NormalizeOrNull(guest.Email),
                    NormalizeOrNull(guest.PhoneNumber),
                    "guest-web"),
                CancellationToken.None);

            reservation = await ApiClient.GetReservationByIdAsync(reservationId, CancellationToken.None);
            if (reservation is not null)
            {
                reservationTrip = await ApiClient.GetTripByIdAsync(reservation.TripId, CancellationToken.None);
                ticketQrBase64 = GenerateQrBase64(reservation.QrCode);
            }

            message = reservation is null
                ? $"Reserva creada con ID {reservationId}."
                : "Reserva creada exitosamente.";

            Ui.ShowSuccess("Reserva creada", message);

            await LoadAvailableTripsAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
            Ui.ShowError("No se pudo crear la reserva", ex.Message);
        }
    }

    private sealed class GuestReservationForm
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string PhoneNumber { get; set; } = string.Empty;
    }

    private async Task DownloadReservationTicketAsync()
    {
        if (reservation is null)
        {
            return;
        }

        reservationTrip ??= await ApiClient.GetTripByIdAsync(reservation.TripId, CancellationToken.None);
        ticketQrBase64 ??= GenerateQrBase64(reservation.QrCode);

        var content = BuildReservationTicketHtml(reservation, reservationTrip, ticketQrBase64);
        await JS.InvokeVoidAsync("sgaUi.downloadHtmlFile", $"reserva-{reservation.Id}.html", content);
        Ui.ShowSuccess("Ticket descargado", "El archivo de ticket se descargo correctamente.");
    }

    private async Task DownloadReservationQrAsync()
    {
        if (reservation is null || string.IsNullOrWhiteSpace(ticketQrBase64))
        {
            return;
        }

        await JS.InvokeVoidAsync("sgaUi.downloadBase64File", $"reserva-qr-{reservation.Id}.png", "image/png", ticketQrBase64);
        Ui.ShowSuccess("QR descargado", "La imagen QR se descargo correctamente.");
    }

    private static string GenerateQrBase64(string qrValue)
    {
        using var generator = new QRCoder.QRCodeGenerator();
        using var data = generator.CreateQrCode(qrValue, QRCoder.QRCodeGenerator.ECCLevel.Q);
        var qrCode = new QRCoder.PngByteQRCode(data);
        var bytes = qrCode.GetGraphic(20);
        return Convert.ToBase64String(bytes);
    }

    private static string? NormalizeOrNull(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private static string BuildReservationTicketHtml(
        SGA.Web.Models.ReservationResponse reservation,
        SGA.Web.Models.TripResponse? trip,
        string? qrBase64)
    {
        var routeLabel = trip is null ? $"Ruta ID {reservation.TripId}" : GetRouteLabel(trip);
        var departure = trip is null ? "N/D" : FormatLocalDateTime(trip.ScheduledDepartureTime);
        var arrival = trip is null ? "N/D" : FormatLocalDateTime(trip.ScheduledArrivalTime);
        var qrImage = string.IsNullOrWhiteSpace(qrBase64)
            ? string.Empty
            : $"<img alt='QR de reserva' style='width:180px;height:180px;border:1px solid #d1d5db;border-radius:8px;padding:8px;background:#fff;' src='data:image/png;base64,{qrBase64}' />";

                return $@"<!doctype html>
<html lang='es'>
<head>
    <meta charset='utf-8' />
    <title>Ticket Reserva {reservation.Id}</title>
</head>
<body style='font-family:Segoe UI,Arial,sans-serif;background:#f8fafc;padding:24px;color:#1f2937;'>
    <section style='max-width:620px;margin:0 auto;background:#fff;border:1px solid #e5e7eb;border-radius:14px;padding:22px;'>
        <h2 style='margin:0 0 12px;color:#005f73;'>Ticket SGA-ITLA</h2>
        <p style='margin:4px 0;'><strong>Reserva:</strong> {reservation.Id}</p>
        <p style='margin:4px 0;'><strong>Viaje:</strong> {reservation.TripId}</p>
        <p style='margin:4px 0;'><strong>Ruta:</strong> {EscapeHtml(routeLabel)}</p>
        <p style='margin:4px 0;'><strong>Salida:</strong> {departure}</p>
        <p style='margin:4px 0;'><strong>Llegada:</strong> {arrival}</p>
        <p style='margin:4px 0;'><strong>Estado:</strong> {EscapeHtml(reservation.Status)}</p>
        <p style='margin:4px 0;'><strong>Turno:</strong> {reservation.QueueNumber}</p>
        <p style='margin:4px 0;'><strong>Codigo QR:</strong> {EscapeHtml(reservation.QrCode)}</p>
        <p style='margin:4px 0;'><strong>Generado:</strong> {FormatLocalDateTime(reservation.CreatedAt)}</p>
        <div style='margin-top:14px;'>{qrImage}</div>
    </section>
</body>
</html>";
    }

    private static string GetRouteLabel(SGA.Web.Models.TripResponse trip)
        => string.IsNullOrWhiteSpace(trip.RouteName) ? $"Ruta ID {trip.RouteId}" : trip.RouteName;

    private static string FormatLocalDateTime(DateTime value)
        => value.ToLocalTime().ToString("dd/MM/yyyy hh:mm tt");

    private static string EscapeHtml(string value)
        => System.Net.WebUtility.HtmlEncode(value);
}